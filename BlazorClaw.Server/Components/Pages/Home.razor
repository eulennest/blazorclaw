@page "/"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Nav

<PageTitle>Chat - BlazorClaw</PageTitle>

<div id="chat-container">
    <div id="messages"></div>
    <div class="input-area">
        <textarea id="user-input" placeholder="Nachricht eingeben..."></textarea>
        <button id="send-btn">Senden</button>
    </div>
</div>

<style>
    #chat-container { display: flex; flex-direction: column; height: 80vh; gap: 10px; padding: 20px; }
    #messages { flex: 1; overflow-y: auto; border: 1px solid #ccc; padding: 15px; border-radius: 8px; }
    .message { margin-bottom: 10px; padding: 10px; border-radius: 8px; max-width: 80%; }
    .user { background: #e0f7fa; align-self: flex-end; margin-left: auto; }
    .assistant { background: #f5f5f5; align-self: flex-start; }
    .input-area { display: flex; gap: 10px; }
    textarea { flex: 1; height: 60px; padding: 10px; border: 1px solid #ccc; border-radius: 8px; }
    button { padding: 0 20px; border-radius: 8px; border: 1px solid #ccc; cursor: pointer; }
    .message table { border-collapse: collapse; width: 100%; margin: 10px 0; }
    .message th, .message td { border: 1px solid #555; padding: 8px; text-align: left; }
    .message th { background-color: #333; }
    .message code { background: #333; padding: 2px 4px; border-radius: 4px; }
    .message pre { background: #333; padding: 10px; border-radius: 5px; overflow-x: auto; }
</style>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
    let chatHistory = [];

    document.getElementById('send-btn').addEventListener('click', async () => {
        const input = document.getElementById('user-input');
        const content = input.value;
        if (!content) return;
        
        chatHistory.push({ role: 'user', content: content });
        
        const msgDiv = document.createElement('div');
        msgDiv.className = 'message user';
        msgDiv.textContent = content;
        document.getElementById('messages').appendChild(msgDiv);
        input.value = '';

        const response = await fetch('/v1/chat/completions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                model: 'openrouter/mistralai/mistral-large', 
                messages: chatHistory
            })
        });
        
        const data = await response.json();
        
        if (data.error) {
            const errorDiv = document.createElement('div');
            errorDiv.className = 'message assistant';
            errorDiv.style.color = 'red';
            errorDiv.textContent = 'Fehler: ' + data.error.message;
            document.getElementById('messages').appendChild(errorDiv);
        } else {
            const assistantMsg = data.choices[0].message.content;
            chatHistory.push({ role: 'assistant', content: assistantMsg });

            const aiDiv = document.createElement('div');
            aiDiv.className = 'message assistant';
            aiDiv.innerHTML = marked.parse(assistantMsg);
            document.getElementById('messages').appendChild(aiDiv);
        }
    });
</script>
