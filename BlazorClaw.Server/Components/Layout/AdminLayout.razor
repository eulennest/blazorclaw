                </NavLink>
            </div>
            
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <i class="bi bi-gear-fill"></i> Übersicht
                </NavLink>
            </div>
            
            <div class="px-3 py-2 text-muted small border-bottom">
                <strong>Konfiguration</strong>
