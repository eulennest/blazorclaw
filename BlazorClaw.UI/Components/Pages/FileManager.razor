@page "/filemanager"
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Utils
@using BlazorClaw.Core.VFS
@using BlazorClaw.Core.VFS.Systems
@using Microsoft.Extensions.DependencyInjection
@inject ILogger<FileManager> Logger
@inject IServiceProvider serviceProvider
@inject AuthenticationStateProvider authenticationStateProvider
@inject UserManager<ApplicationUser> userManager

<PageTitle>Dateimanager</PageTitle>

<div class="container-fluid mt-3" style="height: calc(100vh - 80px);">
    <h2><i class="bi bi-folder"></i> Dateimanager</h2>
    
    <!-- Breadcrumb Navigation -->
    <div class="row mb-3">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <button class="btn btn-link btn-sm p-0" @onclick="() => SelectDirectory(VfsPath.Root)">
                            <i class="bi bi-house"></i> Root
                        </button>
                    </li>
                    @foreach (var segment in GetBreadcrumbs())
                    {
                        <li class="breadcrumb-item @(segment.IsCurrent ? "active" : "")">
                            <button class="btn btn-link btn-sm p-0" @onclick="() => SelectDirectory(segment.Path)">
                                @segment.Name
                            </button>
                        </li>
                    }
                </ol>
            </nav>
        </div>
    </div>

    <div class="row mt-3" style="height: calc(100vh - 200px);">
        <!-- File List (Full Width) -->
        <div class="col-12" style="overflow-y: auto;">
            @if (isLoading)
            {
                <div class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Laden...</span>
                </div>
            }
            else
            {
                <table class="table table-sm table-hover">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50%;">Name</th>
                            <th style="width: 20%;">Größe</th>
                            <th style="width: 30%;">Geändert</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Parent folder button -->
                        @if (!currentPath.IsRoot)
                        {
                            <tr style="cursor: pointer;" @onclick="() => SelectDirectory(currentPath.ParentPath)" class="table-light">
                                <td>
                                    <i class="bi bi-arrow-up"></i>
                                    <span class="ms-2 fw-bold">../</span>
                                </td>
                                <td></td>
                                <td></td>
                            </tr>
                        }

                        @if (itemInfos.Any())
                        {
                            @foreach (var info in itemInfos)
                            {
                                <tr style="cursor: pointer;" @onclick="() => SelectItem(info.Entry.Path)" class="@(selectedPath == info.Entry.Path ? "table-active" : "")">
                                    <td>
                                        @if (info.Entry.Path.IsDirectory)
                                        {
                                            <i class="bi bi-folder-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-file"></i>
                                        }
                                        <span class="ms-2">@info.Name</span>
                                    </td>
                                    <td class="small text-muted">
                                        @if (!info.Entry.Path.IsDirectory)
                                        {
                                            <span title="@info.Length bytes">@FormatSize(info.Length)</span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @if (info != null)
                                        {
                                            @info.LastWriteTime.ToString("dd.MM.yyyy HH:mm")
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">Verzeichnis ist leer</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- Right: Editor/Preview (Hidden for now) -->
        <div class="col-12" style="overflow-y: auto; display: none;">
            @if (selectedPath == null)
            {
                <div class="alert alert-secondary">Wähle eine Datei aus</div>
            }
            else if (selectedPath.Value.IsDirectory)
            {
                <div class="alert alert-info">
                    <strong>@selectedPath.Value.EntityName</strong> ist ein Verzeichnis
                </div>
            }
            else
            {
                <h5>@selectedPath.Value.EntityName</h5>
                <small class="text-muted">@selectedPath.Value.Path</small>
                <hr />

                @if (fileContent == null && !contentError)
                {
                    <div class="spinner-border spinner-border-sm" role="status">
                        <span class="visually-hidden">Laden...</span>
                    </div>
                }
                else if (contentError)
                {
                    <div class="alert alert-danger">Binärdatei oder Fehler beim Laden</div>
                }
                else
                {
                    <textarea class="form-control font-monospace" style="height: 400px; font-size: 0.85rem;" readonly>@fileContent</textarea>
                }
            }
        </div>
    </div>
</div>

@code {
    private IVfsSystem? vfs;
    private VfsPath currentPath = VfsPath.Root;
    private VfsPath? selectedPath;
    private List<VfsPathInfo> itemInfos = new();
    private string? fileContent;
    private bool contentError;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = userManager.GetUserId(user);

            vfs = serviceProvider.GetRequiredService<IVfsSystem>();
            await SelectDirectory(VfsPath.Root);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing FileManager");
        }
    }


    private async Task SelectDirectory(VfsPath path)
    {
        isLoading = true;
        selectedPath = null;
        fileContent = null;
        contentError = false;
        itemInfos.Clear();

        try
        {
            if (vfs == null) return;

            currentPath = path;

            // Load all subpaths with metadata
            var infos = new List<Task<VfsPathInfo>>();
            await foreach (var subPath in vfs.GetSubPathsAsync(path))
            {
                infos.Add(vfs.GetMetaInfoAsync(subPath));
            }
            itemInfos = (await Task.WhenAll(infos))
                        .OrderBy(x => x.Entry.Path.IsDirectory ? 0 : 1).ThenBy(x => x.Name).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading directory: {Path}", path);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectItem(VfsPath path)
    {
        selectedPath = path;
        fileContent = null;
        contentError = false;

        if (path.IsDirectory)
        {
            await SelectDirectory(path);
        }
        else
        {
            // Load file content
            try
            {
                if (vfs == null) return;

                using var stream = await vfs.OpenFileAsync(path, FileMode.Open, FileAccess.Read);
                using var reader = new StreamReader(stream);
                fileContent = await reader.ReadToEndAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading file: {Path}", path);
                contentError = true;
            }
        }
    }

    private string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private List<BreadcrumbItem> GetBreadcrumbs()
    {
        var items = new List<BreadcrumbItem>();
        var path = currentPath;

        // Sammle alle Parent-Paths bis Root
        while (!path.IsRoot)
        {
            items.Add(new BreadcrumbItem
            {
                Name = path.EntityName ?? "Root",
                Path = path,
                IsCurrent = path == currentPath
            });
            
            if (path.IsRoot) break;
            path = path.ParentPath;
        }

        // Reverse um von Root zu current zu gehen
        items.Reverse();
        return items;
    }

    private class BreadcrumbItem
    {
        public string Name { get; set; } = "";
        public VfsPath Path { get; set; }
        public bool IsCurrent { get; set; }
    }
}
