@page "/filemanager"
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Utils
@using BlazorClaw.Core.VFS
@using BlazorClaw.Core.VFS.Systems
@using Microsoft.Extensions.DependencyInjection
@inject ILogger<FileManager> Logger
@inject IServiceProvider serviceProvider
@inject AuthenticationStateProvider authenticationStateProvider
@inject UserManager<ApplicationUser> userManager

<PageTitle>Dateimanager</PageTitle>

<div class="container-fluid mt-3" style="height: calc(100vh - 80px);">
    <h2><i class="bi bi-folder"></i> Dateimanager</h2>
    
    <!-- Breadcrumb Navigation -->
    <div class="row mb-3">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <button class="btn btn-link btn-sm p-0" @onclick="() => SelectDirectory(VfsPath.Root)">
                            <i class="bi bi-house"></i> Root
                        </button>
                    </li>
                    @foreach (var segment in GetBreadcrumbs())
                    {
                        <li class="breadcrumb-item @(segment.IsCurrent ? "active" : "")">
                            <button class="btn btn-link btn-sm p-0" @onclick="() => SelectDirectory(segment.Path)">
                                @segment.Name
                            </button>
                        </li>
                    }
                </ol>
            </nav>
        </div>
    </div>

    <div class="row mt-3" style="height: calc(100vh - 200px);">
        <!-- File List (Full Width) -->
        <div class="col-12" style="overflow-y: auto;">
            @if (isLoading)
            {
                <div class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Laden...</span>
                </div>
            }
            else
            {
                <table class="table table-sm table-hover">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40%;">Name</th>
                            <th style="width: 15%;">Größe</th>
                            <th style="width: 25%;">Geändert</th>
                            <th style="width: 20%;">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Parent folder button -->
                        @if (!currentPath.IsRoot)
                        {
                            <tr style="cursor: pointer;" @onclick="() => SelectDirectory(currentPath.ParentPath)" class="table-light">
                                <td>
                                    <i class="bi bi-arrow-up"></i>
                                    <span class="ms-2 fw-bold">../</span>
                                </td>
                                <td></td>
                                <td></td>
                                <td></td>
                            </tr>
                        }

                        @if (itemInfos.Any())
                        {
                            @foreach (var info in itemInfos)
                            {
                                <tr style="cursor: pointer;" @onclick="() => SelectItem(info.Entry.Path)" class="@(selectedPath == info.Entry.Path ? "table-active" : "")">
                                    <td>
                                        @if (info.Entry.Path.IsDirectory)
                                        {
                                            <i class="bi bi-folder-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="@GetFileIcon(info.Name)"></i>
                                        }
                                        <span class="ms-2">@info.Name</span>
                                    </td>
                                    <td class="small text-muted">
                                        @if (!info.Entry.Path.IsDirectory)
                                        {
                                            <span title="@info.Length bytes">@FormatSize(info.Length)</span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @if (info != null)
                                        {
                                            @info.LastWriteTime.ToString("dd.MM.yyyy HH:mm")
                                        }
                                    </td>
                                    <td class="small text-nowrap">
                                        @if (!info.Entry.Path.IsDirectory)
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick:stopPropagation="true" @onclick="() => OpenViewer(info)">
                                                <i class="bi bi-eye"></i> Öffnen
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick:stopPropagation="true" @onclick="() => DownloadFile(info)">
                                                <i class="bi bi-download"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick:stopPropagation="true" @onclick="() => SelectDirectory(info.Entry.Path)">
                                                <i class="bi bi-arrow-right"></i> Öffnen
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">Verzeichnis ist leer</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>
</div>

<!-- Viewer Modal -->
@if (viewerInfo != null)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="@GetFileIcon(viewerInfo.Name)"></i>
                        @viewerInfo.Name
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseViewer"></button>
                </div>
                <div class="modal-body" style="max-height: 60vh; overflow-y: auto;">
                    @if (fileContent == null && !contentError)
                    {
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Laden...</span>
                        </div>
                    }
                    else if (contentError)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle"></i>
                            Binärdatei oder Fehler beim Laden - nur Download verfügbar
                        </div>
                    }
                    else
                    {
                        <textarea class="form-control font-monospace" style="height: 50vh; font-size: 0.85rem;" @bind="fileContent"></textarea>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseViewer">Schließen</button>
                    <button type="button" class="btn btn-primary" @onclick="() => DownloadFile(viewerInfo)">
                        <i class="bi bi-download"></i> Download
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IVfsSystem? vfs;
    private VfsPath currentPath = VfsPath.Root;
    private VfsPath? selectedPath;
    private List<VfsPathInfo> itemInfos = new();
    private string? fileContent;
    private bool contentError;
    private bool isLoading;
    private VfsPathInfo? viewerInfo;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = userManager.GetUserId(user);

            vfs = serviceProvider.GetRequiredService<IVfsSystem>();
            await SelectDirectory(VfsPath.Root);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing FileManager");
        }
    }


    private async Task SelectDirectory(VfsPath path)
    {
        isLoading = true;
        selectedPath = null;
        fileContent = null;
        contentError = false;
        itemInfos.Clear();

        try
        {
            if (vfs == null) return;

            currentPath = path;

            // Load all subpaths with metadata
            var infos = new List<Task<VfsPathInfo>>();
            await foreach (var subPath in vfs.GetSubPathsAsync(path))
            {
                infos.Add(vfs.GetMetaInfoAsync(subPath).AsTask());
            }
            itemInfos = (await Task.WhenAll(infos))
                        .OrderBy(x => x.Entry.Path.IsDirectory ? 0 : 1).ThenBy(x => x.Name).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading directory: {Path}", path);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectItem(VfsPath path)
    {
        selectedPath = path;
        fileContent = null;
        contentError = false;

        if (path.IsDirectory)
        {
            await SelectDirectory(path);
        }
        else
        {
            // Load file content
            try
            {
                if (vfs == null) return;

                using var stream = await vfs.OpenFileAsync(path, FileMode.Open, FileAccess.Read);
                using var reader = new StreamReader(stream);
                fileContent = await reader.ReadToEndAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading file: {Path}", path);
                contentError = true;
            }
        }
    }

    private string FormatSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private List<BreadcrumbItem> GetBreadcrumbs()
    {
        var items = new List<BreadcrumbItem>();
        var path = currentPath;

        // Sammle alle Parent-Paths bis Root
        while (!path.IsRoot)
        {
            items.Add(new BreadcrumbItem
            {
                Name = path.EntityName ?? "Root",
                Path = path,
                IsCurrent = path == currentPath
            });
            
            if (path.IsRoot) break;
            path = path.ParentPath;
        }

        // Reverse um von Root zu current zu gehen
        items.Reverse();
        return items;
    }

    private class BreadcrumbItem
    {
        public string Name { get; set; } = "";
        public VfsPath Path { get; set; }
        public bool IsCurrent { get; set; }
    }

    private string GetFileIcon(string filename)
    {
        var ext = Path.GetExtension(filename).ToLowerInvariant();
        
        // Bild-Dateien
        if (new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".svg" }.Contains(ext))
            return "bi bi-image text-info";
        
        // Dokumente
        if (new[] { ".pdf" }.Contains(ext))
            return "bi bi-file-pdf text-danger";
        if (new[] { ".doc", ".docx", ".odt" }.Contains(ext))
            return "bi bi-file-word text-primary";
        if (new[] { ".xls", ".xlsx", ".csv", ".ods" }.Contains(ext))
            return "bi bi-file-spreadsheet text-success";
        
        // Code & Config
        if (new[] { ".cs", ".js", ".ts", ".py", ".java", ".cpp", ".c", ".rb", ".go", ".rs" }.Contains(ext))
            return "bi bi-file-code text-secondary";
        if (new[] { ".json", ".xml", ".yaml", ".yml", ".toml", ".ini", ".conf", ".config" }.Contains(ext))
            return "bi bi-gear text-muted";
        
        // Text
        if (new[] { ".txt", ".md", ".log", ".sh", ".bash", ".ps1", ".bat" }.Contains(ext))
            return "bi bi-file-text text-dark";
        
        // Archive
        if (new[] { ".zip", ".rar", ".7z", ".tar", ".gz", ".bz2" }.Contains(ext))
            return "bi bi-file-zip text-warning";
        
        // Video & Audio
        if (new[] { ".mp4", ".avi", ".mov", ".mkv", ".flv", ".wmv" }.Contains(ext))
            return "bi bi-film text-info";
        if (new[] { ".mp3", ".wav", ".flac", ".aac", ".ogg", ".m4a" }.Contains(ext))
            return "bi bi-music-note text-info";
        
        // Default
        return "bi bi-file text-muted";
    }

    private async Task OpenViewer(VfsPathInfo info)
    {
        viewerInfo = info;
        fileContent = null;
        contentError = false;

        try
        {
            if (vfs == null) return;

            using var stream = await vfs.OpenFileAsync(info.Entry.Path, FileMode.Open, FileAccess.Read);
            
            // Limit to 1MB for preview
            if (stream.Length > 1024 * 1024)
            {
                contentError = true;
                return;
            }

            using var reader = new StreamReader(stream);
            fileContent = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading file: {Path}", info.Path);
            contentError = true;
        }
    }

    private void CloseViewer()
    {
        viewerInfo = null;
        fileContent = null;
        contentError = false;
    }

    private async Task DownloadFile(VfsPathInfo info)
    {
        try
        {
            if (vfs == null) return;

            using var stream = await vfs.OpenFileAsync(info.Entry.Path, FileMode.Open, FileAccess.Read);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            
            var fileBytes = ms.ToArray();
            var base64 = Convert.ToBase64String(fileBytes);
            
            // Trigger browser download
            await JS.InvokeVoidAsync("downloadFile", info.Name, base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error downloading file: {Path}", info.Path);
        }
    }

    [Inject]
    protected IJSRuntime JS { get; set; } = default!;
}
