@page "/"
@attribute [Authorize]
@using BlazorClaw.Core.Sessions
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using BlazorClaw.Core.Models
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Services
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Nav
@inject ISessionQueryService SessionQueryService
@inject ISessionManager sessionManager
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ApplicationDbContext Db
@inject ILogger<Home> Logger

<PageTitle>Dashboard - BlazorClaw</PageTitle>

<h1>Willkommen zurück!</h1>

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Deine Sessions</h4>
        <button class="btn btn-primary btn-sm" @onclick="CreateNewSession">
            <i class="bi bi-plus-lg"></i> Neue Session
        </button>
    </div>

    @if (sessions == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Laden...</span>
            </div>
        </div>
    }
    else if (!sessions.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Noch keine Sessions vorhanden. Starte eine neue Session!
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Titel</th>
                        <th>Modell</th>
                        <th>User</th>
                        <th>Letzte Aktivität</th>
                        <th>Erstellt</th>
                        <th style="width: 120px;">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in sessions)
                    {
                        var isGuest = string.IsNullOrEmpty(session.UserId);
                        var isMain = !isGuest && session.UserId == session.Id.ToString();
                        var iconClass = isGuest ? "bi bi-person-x" : (isMain ? "bi bi-person" : "bi bi-people");
                        var name = uList.FirstOrDefault(u => u.Id.Equals(session.UserId))?.UserName;
                        <tr>
                            <td>
                                <i class="@iconClass"></i>
                                <a href="/chat/@session.Id" class="text-decoration-none">
                                    <strong>@session.Title</strong>
                                </a>
                            </td>
                            <td><code class="small">@session.CurrentModel</code></td>
                            <td>@(name ?? "GUEST")</td>
                            <td>@session.LastUsedAt.ToLocalTime().ToString("g")</td>
                            <td>@session.CreatedAt.ToLocalTime().ToString("d")</td>
                            <td>
                                <a href="/chat/@session.Id" class="btn btn-outline-primary btn-sm" title="Öffnen">
                                    <i class="bi bi-chat"></i>
                                </a>
                                <button class="btn btn-outline-danger btn-sm ms-1" @onclick="() => ShowDeleteConfirmation(session)" disabled="@isDeleting" title="Löschen">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal @(showDeleteModal ? "show d-block" : "")" tabindex="-1" style="@(showDeleteModal ? "display: block; background: rgba(0,0,0,0.5);" : "display: none;")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Session löschen</h5>
                <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
            </div>
            <div class="modal-body">
                @if (sessionToDelete != null)
                {
                    <p>Möchtest du die Session <strong>"@sessionToDelete.Title"</strong> wirklich löschen?</p>
                    <p class="text-warning"><small><i class="bi bi-exclamation-triangle"></i> Diese Aktion kann nicht rückgängig gemacht werden.</small></p>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">Abbrechen</button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Löschen
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ChatSession>? sessions;
    private bool isAdmin;
    private string? userId;
    private bool showDeleteModal = false;
    private ChatSession? sessionToDelete;
    private bool isDeleting = false;
    private List<ApplicationUser> uList = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            userId = UserManager.GetUserId(user);
            isAdmin = user.IsInRole("Admin");

            sessions = isAdmin
                ? await SessionQueryService.GetAllSessionsAsync()
                : await SessionQueryService.GetSessionsForUserAsync(userId!);
        }

        uList = await Db.Users.ToListAsync();
    }

    private async Task CreateNewSession()
    {
        var newId = Guid.NewGuid();
        if (!await Db.ChatSessions.AnyAsync(o => o.Id.ToString() == userId))
        {
            newId = Guid.Parse(userId!);
        }
        
        var sess = await sessionManager.GetOrCreateSessionAsync(newId, null, userId);
        if (sess != null) Nav.NavigateTo($"/chat/{sess.Session.Id}");
    }

    private void ShowDeleteConfirmation(ChatSession session)
    {
        sessionToDelete = session;
        showDeleteModal = true;
    }

    private async Task ConfirmDelete()
    {
        if (sessionToDelete == null)
            return;

        isDeleting = true;
        try
        {
            await sessionManager.DeleteSessionAsync(sessionToDelete.Id);

            showDeleteModal = false;
            sessionToDelete = null;
            
            // Reload sessions
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            sessions = isAdmin
                ? await SessionQueryService.GetAllSessionsAsync()
                : await SessionQueryService.GetSessionsForUserAsync(userId!);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting session");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
