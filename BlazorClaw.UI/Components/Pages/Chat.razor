@page "/chat/{SessionId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using BlazorClaw.Core.Sessions
@using Markdig
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.SignalR.Client
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Models
@using BlazorClaw.Core.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.AI
@inject NavigationManager Nav
@inject ISessionQueryService SessionQueryService
@inject ISessionManager sessionManager
@inject IHttpContextAccessor contextAccessor
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Chat> logger
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Chat - BlazorClaw</PageTitle>

<div class="chat-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <button class="new-chat-btn" @onclick="NewChat">
                <i class="bi bi-plus-lg"></i> New Chat
            </button>
        </div>
        <div class="sessions-list">
            @foreach (var session in sessions)
            {
                var isGuest = string.IsNullOrEmpty(session.UserId);
                var isMain = !isGuest && session.UserId == session.Id.ToString();
                var iconClass = isGuest ? "bi bi-person-x" : (isMain ? "bi bi-person" : "bi bi-people");
                <a href="/chat/@session.Id"
                       class="session-item @(session.Id == SessionId ? "active" : "")">
                    <i class="@iconClass"></i>
                    <span class="session-title">@session.Title</span>
                </a>
            }
        </div>
    </aside>

    <!-- Main Chat Area -->
    <main class="chat-main">
        <div class="chat-header">
            <h2>@currentSession?.Session.Title</h2>
            @if (modelFavorites.Any())
            {
                <select class="model-select" @bind="selectedModel">
                    @foreach (var model in modelFavorites)
                    {
                        <option value="@model.InternalName">@model.Name</option>
                    }
                </select>
            }
            else
            {
                <select class="model-select" @bind="selectedModel">
                    <option value="openrouter/mistralai/mistral-large">Mistral Large</option>
                    <option value="openrouter/anthropic/claude-sonnet-4-6">Claude Sonnet</option>
                    <option value="openrouter/openai/gpt-4o">GPT-4o</option>
                </select>
            }
        </div>

        <div class="messages-container" id="messages-container">
            @if (!messages.Any() && !isLoading)
            {
                <div class="empty-state">
                    <div class="empty-icon">💬</div>
                    <h3>How can I help you today?</h3>
                    <p>Start a conversation by typing a message below.</p>
                </div>
            }
            @foreach (var msg in messages.ToArray())
            {
                if (!showTools && msg.Role == ChatRole.Tool) continue;
                <div class="message role-@(msg.Role)">
                    @if (msg.Role != ChatRole.System)
                    {
                        <div class="message-avatar">
                            @if (msg.Role == ChatRole.User)
                            {
                                <i class="bi bi-person"></i>
                            }
                            else
                            {
                                <i class="bi bi-robot"></i>
                            }
                        </div>
                    }
                    <div class="message-content">
                        <div class="message-time" title="@msg.CreatedAt?.ToString("dd.MM.yyyy HH:mm:ss")">@msg.CreatedAt?.ToString("HH:mm")</div>
                        @foreach (var item in msg.Contents)
                        {
                            if (item is TextContent txt)
                            {
                                @((MarkupString)RenderMarkdown(txt.Text))
                            }
                            else if (item is UriContent uriContent)
                            {
                                <div class="media-container">
                                    @if (uriContent.MediaType.StartsWith("audio"))
                                    {
                                        <audio controls>
                                            <source src="@uriContent.Uri" type="@uriContent.MediaType">
                                            Dein Browser unterstützt das Audio-Element nicht.
                                        </audio>
                                    }
                                    else if (uriContent.MediaType.StartsWith("video"))
                                    {
                                        <video controls>
                                            <source src="@uriContent.Uri" type="@uriContent.MediaType">
                                            Dein Browser unterstützt das Video-Element nicht.
                                        </video>
                                    }
                                    else if (uriContent.MediaType.StartsWith("image"))
                                    {
                                        <img src="@uriContent.Uri" alt="Image" />
                                    }
                                    else
                                    {
                                        <a href="@uriContent.Uri" download>
                                            📥 Datei herunterladen
                                        </a>
                                    }
                                </div>
                            }
                            else if (showTools)
                            {
                                if (item is FunctionCallContent toolc)
                                {
                                    <div class="card mb-2 bg-dark tool_call">
                                        <div class="card-body p-2">
                                            <div class="d-flex justify-content-between align-items-start mb-1">
                                                <small><span class="badge bg-primary badge-sm"><!--!--><i class="bi bi-play-circle"></i> Tool: @toolc.Name</span></small><!--!-->
                                            </div>
                                            <div class="p-2 rounded border border-primary">
                                                <pre class="mb-0 mt-1 small">@toolc.Arguments</pre>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else if (item is FunctionResultContent toolr)
                                {
                                    if (!showTools) continue;
                                    <div class="card mb-2 bg-dark tool_output">
                                        <div class="card-body p-2">
                                            <div class="d-flex justify-content-between align-items-start mb-1">
                                                <small><span class="badge bg-secondary badge-sm"><i class="bi bi-wrench"></i> Tool Output:</span></small>
                                            </div>
                                            <pre class="mb-0 small">@toolr.Result</pre>
                                        </div>
                                    </div>
                                }
                                else if (item is TextReasoningContent think)
                                {
                                    <div class="card mb-2 bg-dark reasoning">
                                        <div class="card-body p-2">
                                            <div class="d-flex justify-content-between align-items-start mb-1">
                                                <small>
                                                    <span class="badge bg-info badge-sm">
                                                        <i class="bi bi-lightbulb"></i> Thinking
                                                    </span>
                                                </small>
                                                <pre class="mb-0 small text-muted fst-italic">@think.Text.Trim()</pre>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        }
                    </div>


                    @if (isLoading)
                    {
                        <div class="message assistant">
                            <div class="message-avatar">
                                <i class="bi bi-robot"></i>
                            </div>
                            <div class="message-content">
                                <div class="typing-indicator">
                                    <span></span><span></span><span></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="input-area">
            <textarea @bind="userInput"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      placeholder="Nachricht eingeben..."
                      rows="1"></textarea>
            <button class="send-btn" @onclick="SendMessage" disabled="@isLoading">
                <i class="bi bi-send"></i>
            </button>
        </div>
    </main>
</div>

@code {
    [Parameter]
    public Guid SessionId { get; set; }

    private HubConnection? hubConnection;
    private List<ChatSession> sessions = [];
    private List<ChatMessage> messages = [];
    private ChatSessionState? currentSession;
    private string userInput = "";
    private string selectedModel = string.Empty;
    private List<ModelFavorite> modelFavorites = [];
    private bool isLoading;
    private string? userId;
    private bool isAdmin;
    private bool showTools = true;

    protected override async Task OnInitializedAsync()
    {
        // Load model favorites
        modelFavorites = await Db.ModelFavorites.OrderBy(m => m.Name).ToListAsync();
        if (modelFavorites.Any() && string.IsNullOrEmpty(selectedModel))
        {
            selectedModel = modelFavorites.First().InternalName;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = UserManager.GetUserId(user);

        // Load sessions
        isAdmin = user.IsInRole("Admin");

        // Setup SignalR
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chatHub"), options =>
                {
                    options.Headers.Add("Cookie", contextAccessor.HttpContext?.Request.Headers.Cookie.ToString() ?? string.Empty);
                })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<Guid, ChatMessage>("ReceiveMessage", (sessionId, msg) =>
        {
            logger.LogInformation("Recieve ReceiveMessage for session {SessionId}: {Message}", sessionId, msg);
            if (sessionId == SessionId)
            {
                logger.LogInformation("Message details - Role: {Role}", msg.Role);
                if (!string.IsNullOrWhiteSpace(currentSession?.Session.CurrentModel))
                    selectedModel = currentSession.Session.CurrentModel;

                messages.Add(msg);
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid>("MessageStarted", (sessionId) =>
        {
            logger.LogInformation("Recieve MessageStarted for session {SessionId}", sessionId);

            if (sessionId == SessionId)
            {
                isLoading = true;
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid>("MessageCompleted", (sessionId) =>
        {
            logger.LogInformation("Recieve MessageCompleted for session {SessionId}", sessionId);
            if (sessionId == SessionId)
            {
                isLoading = false;
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid, string>("Error", (sessionId, error) =>
        {
            logger.LogError("Recieve Error for session {SessionId}: {Error}", sessionId, error);
            if (sessionId == SessionId)
            {
                logger.LogInformation("Error message: {Error}", error);
                isLoading = false;
                messages.Add(new ChatMessage(new ChatRole("error"), $"Error: {error}"));
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid, List<ChatMessage>>("HistoryLoaded", (sessionId, history) =>
        {
            logger.LogInformation("Recieve HistoryLoaded for session {SessionId} with {MessageCount} messages", sessionId, history.Count);
            if (sessionId == SessionId)
            {
                logger.LogInformation("History messages: {Count}", history.Count);
                messages = history;
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        await hubConnection.StartAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (hubConnection != null)
        {
            sessions = isAdmin
                ? await SessionQueryService.GetAllSessionsAsync()
                : await SessionQueryService.GetSessionsForUserAsync(userId!);

            var sesi = sessions.FirstOrDefault(s => s.Id == SessionId);
            if (sesi != null)
            {
                currentSession = await sessionManager.GetSessionAsync(SessionId);
                selectedModel = currentSession?.Session.CurrentModel ?? modelFavorites.FirstOrDefault()?.InternalName ?? string.Empty;

                if (!modelFavorites.Any(o => o.InternalName == selectedModel))
                {
                    modelFavorites.Add(new ModelFavorite()
                    {
                        InternalName = selectedModel,
                        Name = selectedModel.Split('/').Last()
                    });
                }
            }

            messages.Clear();
            await hubConnection.InvokeAsync("LoadHistory", SessionId);
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isLoading) return;

        var input = userInput ?? string.Empty;
        userInput = "";
        if (currentSession != null && !string.IsNullOrWhiteSpace(selectedModel) && currentSession.Session.CurrentModel != selectedModel)
        {
            currentSession.Session.CurrentModel = selectedModel;
        }

        if (hubConnection?.State == HubConnectionState.Connected)
        {
            _ = hubConnection.SendAsync("SendMessage", SessionId, input);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task NewChat()
    {
        var newId = Guid.NewGuid();
        var sess = await sessionManager.GetOrCreateSessionAsync(newId, selectedModel);
        if (sess != null) Nav.NavigateTo($"/chat/{sess.Session.Id}");
    }

    private void ScrollToBottom()
    {
        InvokeAsync(async () =>
        {
            await Task.Delay(50);
            await JS.InvokeVoidAsync("scrollIdToEnd", new object[] { "messages-container" });
        });
    }

    private string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
            return string.Empty;

        // Configure Markdig pipeline
        var pipeline = new Markdig.MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .UseAutoLinks(new Markdig.Extensions.AutoLinks.AutoLinkOptions { OpenInNewWindow = true })
            .UseReferralLinks("nofollow", "noopener", "noreferrer")
            .UseMathematics()
            .DisableHtml()
            .Build();

        // Parse Markdown to HTML
        var html = Markdig.Markdown.ToHtml(markdown, pipeline);
        return html;
    }

    private string UriToImageSrc(string url)
    {
        return url;
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}

<style>
    .media-container {
        margin-top: 10px;
    }

        .media-container audio {
            height: 35px; /* Etwas kompakter */
            width: 100%;
            min-width: 300px;
            border-radius: 20px;
            background-color: #f1f3f4;
        }

        .media-container video {
            width: 100%;
            min-width: 300px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            max-width: 100%;
            height: auto;
            border-radius: 8px;
        }

        .media-container a {
            text-decoration: none;
            color: #0066cc;
            font-weight: bold;
        }

            .media-container a:hover {
                color: #0052a3;
                text-decoration: underline;
            }

    pre {
        white-space: pre-wrap;
        word-break: break-word;
        padding: 8px;
        border-radius: 4px;
        max-height: 400px;
        overflow-y: auto;
    }

    .reasoning pre {
        border-left: 3px solid #0dcaf0;
    }
</style>
