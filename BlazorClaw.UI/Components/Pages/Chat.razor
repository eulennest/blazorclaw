@page "/chat/{SessionId:guid}"
@attribute [Authorize]
@using BlazorClaw.Core.Sessions
@using Markdig
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.SignalR.Client
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Models
@using BlazorClaw.Core.Services
@using BlazorClaw.Core.DTOs
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Nav
@inject ISessionQueryService SessionQueryService
@inject ISessionManager sessionManager
@inject IHttpContextAccessor contextAccessor
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Chat> logger
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Chat - BlazorClaw</PageTitle>

<div class="chat-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <button class="new-chat-btn" @onclick="NewChat">
                <i class="bi bi-plus-lg"></i> New Chat
            </button>
        </div>
        <div class="sessions-list">
            @foreach (var session in sessions)
            {
                <a href="/chat/@session.Id"
                   class="session-item @(session.Id == SessionId ? "active" : "")">
                    <i class="bi bi-chat-dots"></i>
                    <span class="session-title">@session.Title</span>
                </a>
            }
        </div>
    </aside>

    <!-- Main Chat Area -->
    <main class="chat-main">
        <div class="chat-header">
            <h2>@currentSession?.Session.Title</h2>
            @if (modelFavorites.Any())
            {
                <select class="model-select" @bind="selectedModel">
                    @foreach (var model in modelFavorites)
                    {
                        <option value="@model.InternalName">@model.Name</option>
                    }
                </select>
            }
            else
            {
                <select class="model-select" @bind="selectedModel">
                    <option value="openrouter/mistralai/mistral-large">Mistral Large</option>
                    <option value="openrouter/anthropic/claude-sonnet-4-6">Claude Sonnet</option>
                    <option value="openrouter/openai/gpt-4o">GPT-4o</option>
                </select>
            }
        </div>

        <div class="messages-container" id="messages-container">
            @if (!messages.Any() && !isLoading)
            {
                <div class="empty-state">
                    <div class="empty-icon">💬</div>
                    <h3>How can I help you today?</h3>
                    <p>Start a conversation by typing a message below.</p>
                </div>
            }

            @foreach (var msg in messages.ToArray())
            {
                <div class="message @(msg.IsUser ? "own" : "other") role-@(msg.Role)">
                    <div class="message-avatar">
                        @if (msg.IsUser)
                        {
                            <i class="bi bi-person"></i>
                        }
                        else
                        {
                            <i class="bi bi-robot"></i>
                        }
                    </div>
                    <div class="message-content">
                        @((MarkupString)RenderMarkdown(@msg.Content?.ToString() ?? string.Empty))
                    </div>
                </div>
            }

            @if (isLoading)
            {
                <div class="message assistant">
                    <div class="message-avatar">
                        <i class="bi bi-robot"></i>
                    </div>
                    <div class="message-content">
                        <div class="typing-indicator">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="input-area">
            <textarea @bind="userInput"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      placeholder="Nachricht eingeben..."
                      rows="1"></textarea>
            <button class="send-btn" @onclick="SendMessage" disabled="@isLoading">
                <i class="bi bi-send"></i>
            </button>
        </div>
    </main>
</div>

@code {
    [Parameter]
    public Guid SessionId { get; set; }

    private HubConnection? hubConnection;
    private List<ChatSession> sessions = [];
    private List<ChatMessage> messages = [];
    private ChatSessionState? currentSession;
    private string userInput = "";
    private string selectedModel = string.Empty;
    private List<ModelFavorite> modelFavorites = [];
    private bool isLoading;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        // Load model favorites
        modelFavorites = await Db.ModelFavorites.OrderBy(m => m.Name).ToListAsync();
        if (modelFavorites.Any() && string.IsNullOrEmpty(selectedModel))
        {
            selectedModel = modelFavorites.First().InternalName;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = UserManager.GetUserId(user);

        // Load sessions
        var isAdmin = user.IsInRole("Admin");
        sessions = isAdmin
            ? await SessionQueryService.GetAllSessionsAsync()
            : await SessionQueryService.GetSessionsForUserAsync(userId!);

        // Setup SignalR
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chatHub"), options =>
                {
                    options.Headers.Add("Cookie", contextAccessor.HttpContext?.Request.Headers.Cookie.ToString() ?? string.Empty);
                })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<Guid, ChatMessage>("ReceiveMessage", (sessionId, msg) =>
        {
            logger.LogInformation("Recieve ReceiveMessage for session {SessionId}: {Message}", sessionId, msg.Content);
            if (sessionId == SessionId)
            {
                logger.LogInformation("Message details - Role: {Role}, IsUser: {IsUser}", msg.Role, msg.IsUser);
                messages.Add(msg);
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid>("MessageStarted", (sessionId) =>
        {
            logger.LogInformation("Recieve MessageStarted for session {SessionId}", sessionId);

            if (sessionId == SessionId)
            {
                isLoading = true;
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid>("MessageCompleted", (sessionId) =>
        {
            logger.LogInformation("Recieve MessageCompleted for session {SessionId}", sessionId);
            if (sessionId == SessionId)
            {
                isLoading = false;
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid, string>("Error", (sessionId, error) =>
        {
            logger.LogError("Recieve Error for session {SessionId}: {Error}", sessionId, error);
            if (sessionId == SessionId)
            {
                logger.LogInformation("Error message: {Error}", error);
                isLoading = false;
                messages.Add(new ChatMessage { Role = "error", Content = $"Error: {error}" });
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        hubConnection.On<Guid, List<ChatMessage>>("HistoryLoaded", (sessionId, history) =>
        {
            logger.LogInformation("Recieve HistoryLoaded for session {SessionId} with {MessageCount} messages", sessionId, history.Count);
            if (sessionId == SessionId)
            {
                logger.LogInformation("History messages: {Messages}", string.Join("\n", history.Select(m => $"{m.Role}: {m.Content}")));
                messages = history;
                InvokeAsync(StateHasChanged);
                ScrollToBottom();
            }
        });

        await hubConnection.StartAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (hubConnection != null)
        {

            var sesi = sessions.FirstOrDefault(s => s.Id == SessionId);
            if (sesi != null)
            {
                currentSession = await sessionManager.GetSessionAsync(SessionId);
                selectedModel = currentSession?.Session.CurrentModel ?? modelFavorites.FirstOrDefault()?.InternalName ?? string.Empty;

                if (!modelFavorites.Any(o => o.InternalName == selectedModel))
                {
                    modelFavorites.Add(new ModelFavorite()
                    {
                        InternalName = selectedModel,
                        Name = selectedModel.Split('/').Last()
                    });
                }
            }

            messages.Clear();
            await hubConnection.InvokeAsync("LoadHistory", SessionId);
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isLoading) return;

        var input = userInput ?? string.Empty;
        userInput = "";
        if (currentSession != null && !string.IsNullOrWhiteSpace(selectedModel) && currentSession.Session.CurrentModel != selectedModel)
        {
            currentSession.Session.CurrentModel = selectedModel;
            Db.ChatSessions.Update(currentSession.Session);
            await Db.SaveChangesAsync();
        }

        if (hubConnection?.State == HubConnectionState.Connected)
        {
            _ = hubConnection.SendAsync("SendMessage", SessionId, input);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private void NewChat()
    {
        var newId = Guid.NewGuid();
        Nav.NavigateTo($"/chat/{newId}");
    }

    private void ScrollToBottom()
    {
        InvokeAsync(async () =>
        {
            await Task.Delay(50);
            await JS.InvokeVoidAsync("scrollIdToEnd", new object[] { "messages-container" });
        });
    }

    private string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
            return string.Empty;

        // Configure Markdig pipeline
        var pipeline = new Markdig.MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .UseAutoLinks(new Markdig.Extensions.AutoLinks.AutoLinkOptions { OpenInNewWindow = true })
            .UseReferralLinks("nofollow", "noopener", "noreferrer")
            .UseMathematics()
            .Build();

        // Parse Markdown to HTML
        var html = Markdig.Markdown.ToHtml(markdown, pipeline);
        return html;
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}

<style>
    .chat-layout {
        display: flex;
        height: calc(100vh - 60px);
        margin: -1.5rem;
        background: #1e1e1e;
    }

    .sidebar {
        width: 260px;
        background: #2d2d2d;
        border-right: 1px solid #3d3d3d;
        display: flex;
        flex-direction: column;
        padding: 10px;
        flex-shrink: 0;
    }

    .sidebar-header {
        padding: 10px 0;
        margin-bottom: 10px;
    }

    .new-chat-btn {
        width: 100%;
        padding: 12px;
        background: #4a4a4a;
        border: none;
        border-radius: 8px;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: background 0.2s;
    }

        .new-chat-btn:hover {
            background: #5a5a5a;
        }

    .sessions-list {
        flex: 1;
        overflow-y: auto;
    }

    .session-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px;
        color: #a0a0a0;
        text-decoration: none;
        border-radius: 8px;
        margin-bottom: 4px;
        transition: all 0.2s;
    }

        .session-item:hover {
            background: #3d3d3d;
            color: #fff;
        }

        .session-item.active {
            background: #3d3d3d;
            color: #fff;
        }

    .session-title {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .chat-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: #1e1e1e;
    }

    .chat-header {
        padding: 15px 20px;
        border-bottom: 1px solid #3d3d3d;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .chat-header h2 {
            color: #fff;
            font-size: 1.2rem;
            margin: 0;
        }

    .model-select {
        padding: 8px 12px;
        background: #3d3d3d;
        border: 1px solid #4a4a4a;
        border-radius: 6px;
        color: #fff;
        cursor: pointer;
    }

    .messages-container {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        min-height: 0;
    }

    .empty-state {
        text-align: center;
        color: #a0a0a0;
        padding-top: 100px;
    }

    .empty-icon {
        font-size: 48px;
        margin-bottom: 20px;
    }

    .empty-state h3 {
        color: #fff;
        margin-bottom: 10px;
    }

    .message {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        max-width: 800px;
    }

        .message.own {
            flex-direction: row-reverse;
            margin-left: auto;
        }

    .message-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .message.own .message-avatar {
        background: #10a37f;
    }

    .message.other .message-avatar {
        background: #5436da;
    }

    .message-content {
        padding: 12px 16px;
        border-radius: 12px;
        line-height: 1.5;
        color: #fff;
    }

    .message.own .message-content {
        background: #2d2d2d;
    }

    .message.other .message-content {
        background: #2d2d2d;
    }

    .message.role-error .message-content {
        background: #ff2d2d;
    }

    .message-content code {
        background: #3d3d3d;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: monospace;
    }

    .message-content pre {
        background: #3d3d3d;
        padding: 12px;
        border-radius: 8px;
        overflow-x: auto;
    }

        .message-content pre code {
            background: none;
            padding: 0;
        }

    .typing-indicator {
        display: flex;
        gap: 4px;
    }

        .typing-indicator span {
            width: 8px;
            height: 8px;
            background: #a0a0a0;
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out;
        }

            .typing-indicator span:nth-child(1) {
                animation-delay: 0s;
            }

            .typing-indicator span:nth-child(2) {
                animation-delay: 0.2s;
            }

            .typing-indicator span:nth-child(3) {
                animation-delay: 0.4s;
            }

    @@keyframes bounce {
        0%, 80%, 100% {
            transform: translateY(0);
        }

        40% {
            transform: translateY(-8px);
        }
    }

    .input-area {
        padding: 12px 20px;
        border-top: 1px solid #3d3d3d;
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-shrink: 0;
    }

        .input-area textarea {
            flex: 1;
            padding: 14px;
            background: #3d3d3d;
            border: 1px solid #4a4a4a;
            border-radius: 12px;
            color: #fff;
            resize: none;
            min-height: 50px;
            max-height: 200px;
            font-family: inherit;
            font-size: 1rem;
        }

            .input-area textarea:focus {
                outline: none;
                border-color: #10a37f;
            }

            .input-area textarea::placeholder {
                color: #a0a0a0;
            }

    .send-btn {
        padding: 14px 20px;
        background: #10a37f;
        border: none;
        border-radius: 12px;
        color: #fff;
        cursor: pointer;
        transition: background 0.2s;
    }

        .send-btn:hover:not(:disabled) {
            background: #0d8c6d;
        }

        .send-btn:disabled {
            background: #4a4a4a;
            cursor: not-allowed;
        }
</style>
