@page "/admin/channels"
@using BlazorClaw.Channels.Services
@inject WhatsAppBotHostedService WhatsAppService

<PageTitle>Admin - Kanäle</PageTitle>

<h2>Kanal-Konfiguration</h2>
<p class="text-muted">Verwaltung der Messaging-Kanäle (Telegram, Matrix, WhatsApp, Web).</p>

<div class="mt-4">
    <h5 class="mt-4">Aktive Kanäle</h5>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Kanal</th>
                <th>Status</th>
                <th>Accounts</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><i class="bi bi-telegram"></i> Telegram</td>
                <td><span class="badge bg-success">Aktiv</span></td>
                <td><code>default</code></td>
                <td><a href="/admin/channels/telegram" class="btn btn-sm btn-outline-primary"><i class="bi bi-gear"></i> Bearbeiten</a></td>
            </tr>
            <tr>
                <td><i class="bi bi-whatsapp"></i> WhatsApp</td>
                <td>
                    @if (whatsappAccountCount == 0)
                    {
                        <span class="badge bg-secondary">Inaktiv</span>
                    }
                    else if (whatsappQRCount > 0)
                    {
                        <span class="badge bg-warning">Pairing (@whatsappQRCount/@whatsappAccountCount)</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Aktiv</span>
                    }
                </td>
                <td>
                    @if (whatsappAccountCount == 0)
                    {
                        <span class="text-muted">Keine Accounts konfiguriert</span>
                    }
                    else if (whatsappQRCount > 0)
                    {
                        <span class="text-warning">@whatsappQRCount von @whatsappAccountCount nicht verbunden</span>
                    }
                    else
                    {
                        <span class="text-success">@whatsappAccountCount verbunden</span>
                    }
                </td>
                <td>
                    <a href="/admin/channels/whatsapp" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-gear"></i> Verwalten
                    </a>
                </td>
            </tr>
        </tbody>
    </table>
</div>

@code {
    private int whatsappQRCount = 0;
    private int whatsappAccountCount = 0;

    protected override void OnInitialized()
    {
        whatsappAccountCount = WhatsAppService.GetAccountCount();
        whatsappQRCount = WhatsAppService.GetCurrentQRCodes().Count;
    }
}
