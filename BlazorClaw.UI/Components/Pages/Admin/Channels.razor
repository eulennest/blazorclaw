@page "/admin/channels"

<PageTitle>Admin - Kanäle</PageTitle>

<h2>Kanal-Konfiguration</h2>
<p class="text-muted">Verwaltung der Messaging-Kanäle (Telegram, Matrix, Web).</p>

<div class="mt-4">
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Diese Seite ist ein Platzhalter. Implementierung folgt...
    </div>
    
    <h5 class="mt-4">Aktive Kanäle</h5>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Kanal</th>
                <th>Status</th>
                <th>ID</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><i class="bi bi-telegram"></i> Telegram</td>
                <td><span class="badge bg-success">Aktiv</span></td>
                <td><code>default</code></td>
                <td><button class="btn btn-sm btn-outline-secondary">Bearbeiten</button></td>
            </tr>
        </tbody>
    </table>
</div>