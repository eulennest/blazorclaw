@page "/admin/channels"
@using BlazorClaw.Channels.Services
@using Microsoft.Extensions.DependencyInjection
@inject WhatsAppBotHostedService WhatsAppService
@inject IServiceProvider sp

<PageTitle>Admin - Kanäle</PageTitle>

<h2>Kanal-Konfiguration</h2>
<p class="text-muted">Verwaltung der Messaging-Kanäle (Telegram, Matrix, WhatsApp, Web).</p>

<div class="mt-4">
    <h5 class="mt-4">Aktive Kanäle</h5>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Kanal</th>
                <th>Status</th>
                <th>Accounts</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                @{
                    var tb = BotsEnabled<TelegramBotEntry>();
                }
                <td><i class="bi bi-telegram"></i> Telegram</td>
                <td><span class="badge @(tb.Length > 0 ? "bg-sucess" : "bg-secondary")">@(tb.Length > 0 ? "Aktiv" : "Inaktiv")</span></td>
                <td><code>@string.Join(", ", tb)</code></td>
                <td><a href="/admin/channels/telegram" class="btn btn-sm btn-outline-primary"><i class="bi bi-gear"></i> Verwalten</a></td>
            </tr>
            <tr>
                @{
                    var mb = BotsEnabled<MatrixBotEntry>();
                }
                <td><i class="bi bi-person-workspace"></i> Matrix</td>
                <td><span class="badge @(mb.Length > 0 ? "bg-success" : "bg-secondary")">@(mb.Length > 0 ? "Aktiv" : "Inaktiv")</span></td>
                <td><code>@string.Join(", ", mb)</code></td>
                <td><a href="/admin/channels/matrix" class="btn btn-sm btn-outline-primary"><i class="bi bi-gear"></i> Verwalten</a></td>
            </tr>
            <tr>
                @{
                    var wb = BotsEnabled<WhatsAppBotEntry>();
                }
                <td><i class="bi bi-whatsapp"></i> WhatsApp</td>
                <td>
                    @if (wb.Length == 0)
                    {
                        <span class="badge bg-secondary">Inaktiv</span>
                    }
                    else if (whatsappQRCount > 0)
                    {
                        <span class="badge bg-warning">Pairing (@whatsappQRCount)</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Aktiv</span>
                    }
                </td>
                <td>
                    @if (wb.Length == 0)
                    {
                        <span class="text-muted">Keine Accounts konfiguriert</span>
                    }
                    else if (whatsappQRCount > 0)
                    {
                        <span class="text-warning"><code>@string.Join(", ", tb)</code> @whatsappQRCount nicht verbunden</span>
                    }
                    else
                    {
                        <span class="text-success"><code>@string.Join(", ", tb)</code></span>
                    }
                </td>
                <td>
                    <a href="/admin/channels/whatsapp" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-gear"></i> Verwalten
                    </a>
                </td>
            </tr>
        </tbody>
    </table>
</div>

@code {
    private int whatsappQRCount = 0;

    protected override void OnInitialized()
    {
        whatsappQRCount = WhatsAppService.GetCurrentQRCodes().Count;
    }

    protected string[] BotsEnabled<T>() where T : BotEntry
    {
        var opts = sp.GetService<Microsoft.Extensions.Options.IOptions<BotConfigs<T>>>()?.Value;
        if (opts == null) return Array.Empty<string>();
        return opts.Where(o => o.Value.Enabled).Select(o => o.Key).ToArray();
    }
}
