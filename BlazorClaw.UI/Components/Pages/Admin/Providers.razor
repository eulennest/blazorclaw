@page "/admin/providers"
@using BlazorClaw.Core.Providers
@using Microsoft.AspNetCore.Components.Forms
@inject IProviderManager ProviderManager
@inject IConfiguration Configuration

<PageTitle>Admin - Provider</PageTitle>

<h2>LLM-Provider</h2>
<p class="text-muted">Konfiguration der KI-Provider (OpenRouter, OpenAI, etc.).</p>

<div class="mt-4">
    <h5>Konfigurierte Provider</h5>
    
    @if (providers == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Laden...</span>
            </div>
        </div>
    }
    else if (!providers.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Keine Provider konfiguriert.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Endpoint</th>
                    <th>Model</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var provider in providers)
                {
                    <tr>
                        <td>
                            <strong>@provider.Key</strong>
                        </td>
                        <td>
                            <code class="small">@provider.Value.Uri</code>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@GetModelForProvider(provider.Key)</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(provider.Value.Token))
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Konfiguriert</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle"></i> Token fehlt</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h5 class="mt-4">Aktuelles Modell</h5>
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <label class="form-label">Modell</label>
                    <InputText @bind-Value="currentModel" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Temperatur</label>
                    <InputNumber @bind-Value="temperature" class="form-control" step="0.1" min="0" max="2" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Max Tokens</label>
                    <InputNumber @bind-Value="maxTokens" class="form-control" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="SaveSettings">
                    <i class="bi bi-check-lg"></i> Speichern
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private Dictionary<string, IProviderConfiguration>? providers;
    private string currentModel = "";
    private double temperature = 0.7;
    private int maxTokens = 2000;

    protected override void OnInitialized()
    {
        // Load providers
        var providerNames = ProviderManager.GetProviders();
        providers = new Dictionary<string, IProviderConfiguration>();
        
        foreach (var name in providerNames)
        {
            var config = ProviderManager.GetProviderConfig(name);
            if (config != null)
            {
                providers[name] = config;
            }
        }

        // Load LLM settings
        currentModel = Configuration["Llm:Model"] ?? "openrouter/mistralai/mistral-large";
        temperature = double.TryParse(Configuration["Llm:Temperature"], out var t) ? t : 0.7;
        maxTokens = int.TryParse(Configuration["Llm:MaxTokens"], out var m) ? m : 2000;
    }

    private string GetModelForProvider(string providerName)
    {
        if (currentModel.StartsWith(providerName + "/"))
        {
            return currentModel.Substring(providerName.Length + 1);
        }
        return currentModel;
    }

    private void SaveSettings()
    {
        // TODO: Save to configuration
        // For now, just show a message
        Console.WriteLine($"Saving: Model={currentModel}, Temp={temperature}, MaxTokens={maxTokens}");
    }
}
