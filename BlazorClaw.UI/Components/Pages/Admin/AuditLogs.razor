@page "/admin/auditlogs"
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>Admin - Audit Logs</PageTitle>

<h2>Audit Logs</h2>
<p class="text-muted">Übersicht aller Systemaktionen und Cron-Job-Ausführungen.</p>

<div class="row mt-4">
    <!-- Filters -->
    <div class="col-12 mb-3">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Filter</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Action</label>
                        <select @bind="filterAction" @bind:event="onchange" class="form-select form-select-sm">
                            <option value="">-- Alle --</option>
                            @foreach (var action in availableActions)
                            {
                                <option value="@action">@action</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Von</label>
                        <input @bind="filterDateFrom" @bind:event="onchange" type="date" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Bis</label>
                        <input @bind="filterDateTo" @bind:event="onchange" type="date" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Session</label>
                        <input @bind="filterSessionId" @bind:event="onchange" type="text" class="form-control form-control-sm" placeholder="Session ID..." />
                    </div>
                    <div class="col-12 mt-2">
                        <button class="btn btn-primary btn-sm" @onclick="ReloadLogs">
                            <i class="bi bi-search"></i> Filtern
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Logs (@totalCount)</h5>
                <small class="text-muted">
                    Zeige @((currentPage - 1) * pageSize + 1) - @Math.Min(currentPage * pageSize, totalCount)
                </small>
            </div>
            <div class="card-body">
                @if (auditLogs == null)
                {
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Laden...</span>
                        </div>
                    </div>
                }
                else if (!auditLogs.Any())
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Keine Logs gefunden.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 5%;">
                                        <a href="#" @onclick:preventDefault @onclick="() => ToggleSort(nameof(AuditLog.Timestamp))"
                                               class="text-white text-decoration-none">
                                            Zeit @GetSortIcon(nameof(AuditLog.Timestamp))
                                        </a>
                                    </th>
                                    <th style="width: 12%;">Action</th>
                                    <th style="width: 15%;">User</th>
                                    <th style="width: 15%;">Session</th>
                                    <th style="width: 40%;">Details</th>
                                    <th style="width: 13%;">Result</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in auditLogs)
                                {
                                    <tr style="cursor: pointer;" @onclick="() => ToggleExpanded(log.Id)">
                                        <td>
                                            <small>@log.Timestamp.ToString("dd.MM.yy HH:mm:ss")</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-info">@log.Action</span>
                                        </td>
                                        <td>
                                            <code class="small">@(log.UserId?.Substring(0, Math.Min(8, log.UserId.Length)) ?? "—")</code>
                                        </td>
                                        <td>
                                            @if (log.SessionId.HasValue)
                                            {
                                                <code class="small">@log.SessionId.ToString()?.Substring(0, 8)...</code>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <small>
                                                @if (log.Details?.Length > 50)
                                                {
                                                    @(log.Details.Substring(0, 50) + "...")
                                                }
                                                else
                                                {
                                                    @log.Details
                                                }
                                            </small>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(log.Result))
                                            {
                                                <span class="badge bg-danger">Error</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">OK</span>
                                            }
                                        </td>
                                    </tr>

                                    @if (expandedLogIds.Contains(log.Id))
                                    {
                                        <tr class="table-active">
                                            <td colspan="6">
                                                <div class="p-3">
                                                    <h6>Details</h6>
                                                    <pre style="font-size: 0.8rem; background: #f8f9fa; padding: 10px; border-radius: 4px; overflow-x: auto;">@log.Details</pre>
                                                    
                                                    @if (!string.IsNullOrEmpty(log.Result))
                                                    {
                                                        <h6 class="mt-3">Error</h6>
                                                        <pre style="font-size: 0.8rem; background: #f8d7da; padding: 10px; border-radius: 4px; overflow-x: auto;">@log.Result</pre>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <nav class="mt-3">
                        <ul class="pagination pagination-sm justify-content-center mb-0">
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" href="#" @onclick:preventDefault @onclick="() => { currentPage = 1; ReloadLogs(); }">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" href="#" @onclick:preventDefault @onclick="() => { currentPage--; ReloadLogs(); }">
                                    Zurück
                                </a>
                            </li>

                            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="#" @onclick:preventDefault @onclick="() => { currentPage = i; ReloadLogs(); }">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link" href="#" @onclick:preventDefault @onclick="() => { currentPage++; ReloadLogs(); }">
                                    Weiter
                                </a>
                            </li>
                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link" href="#" @onclick:preventDefault @onclick="() => { currentPage = totalPages; ReloadLogs(); }">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<AuditLog>? auditLogs;
    private HashSet<Guid> expandedLogIds = new();
    private List<string> availableActions = new();

    // Filters
    private string filterAction = "";
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;
    private string filterSessionId = "";

    // Sorting
    private string sortBy = nameof(AuditLog.Timestamp);
    private bool sortAscending = false;

    // Pagination
    private int pageSize = 50;
    private int currentPage = 1;
    private int totalCount = 0;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableActions();
        await ReloadLogs();
    }

    private async Task LoadAvailableActions()
    {
        availableActions = await Db.AuditLogs
            .Select(l => l.Action)
            .Distinct()
            .OrderBy(a => a)
            .ToListAsync();
    }

    private async Task ReloadLogs()
    {
        currentPage = 1;
        
        var query = Db.AuditLogs.AsQueryable();

        // Filters
        if (!string.IsNullOrEmpty(filterAction))
            query = query.Where(l => l.Action == filterAction);

        if (filterDateFrom.HasValue)
            query = query.Where(l => l.Timestamp >= filterDateFrom.Value);

        if (filterDateTo.HasValue)
            query = query.Where(l => l.Timestamp < filterDateTo.Value.AddDays(1));

        if (!string.IsNullOrEmpty(filterSessionId))
            query = query.Where(l => l.SessionId.ToString()!.Contains(filterSessionId));

        totalCount = await query.CountAsync();

        // Sorting
        query = sortAscending
            ? query.OrderBy(l => EF.Property<object>(l, sortBy))
            : query.OrderByDescending(l => EF.Property<object>(l, sortBy));

        // Pagination
        auditLogs = await query
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();

        expandedLogIds.Clear();
    }

    private void ToggleExpanded(Guid logId)
    {
        if (expandedLogIds.Contains(logId))
            expandedLogIds.Remove(logId);
        else
            expandedLogIds.Add(logId);
    }

    private void ToggleSort(string column)
    {
        if (sortBy == column)
            sortAscending = !sortAscending;
        else
        {
            sortBy = column;
            sortAscending = false;
        }
        ReloadLogs();
    }

    private string GetSortIcon(string column)
    {
        if (sortBy != column) return "↕️";
        return sortAscending ? "↑" : "↓";
    }
}
