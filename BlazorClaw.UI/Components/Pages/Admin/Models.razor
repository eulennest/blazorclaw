@page "/admin/models"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Models
@using BlazorClaw.Core.Providers
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IProviderManager ProviderManager

<PageTitle>Modelle - BlazorClaw</PageTitle>

<h2>Model-Favoriten</h2>
<p class="text-muted">Verwalte deine Lieblingsmodelle für den Chat.</p>

<div class="row mt-4">
    <!-- Add New Model -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Neues Modell hinzufügen</h5>
            </div>
            <div class="card-body">
                <EditForm Model="newModel" OnValidSubmit="AddModel">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText @bind-Value="newModel.Name" class="form-control" placeholder="z.B. Mistral Large" />
                        <ValidationMessage For="() => newModel.Name" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Beschreibung</label>
                        <InputTextArea @bind-Value="newModel.Description" class="form-control" placeholder="Kurze Beschreibung..." rows="2" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Provider wählen</label>
                        <select class="form-select" @bind="selectedProvider" @bind:after="LoadProviderModels">
                            <option value="">-- Provider auswählen --</option>
                            @foreach (var provider in providers)
                            {
                                <option value="@provider">@provider</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Interner Name</label>
                        <InputText @bind-Value="newModel.InternalName" 
                            @oninput="OnModelInput"
                            class="form-control" 
                            placeholder="Tippe um zu suchen..." />
                        <ValidationMessage For="() => newModel.InternalName" />
                        @if (filteredModels.Any())
                        {
                            <ul class="list-group mt-1" style="max-height: 150px; overflow-y: auto; position: absolute; z-index: 1000; width: calc(100% - 3rem);">
                                @foreach (var model in filteredModels)
                                {
                                    <li class="list-group-item list-group-item-action" 
                                        style="cursor: pointer;" 
                                        @onclick="() => SelectModel(model)">
                                        @model
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Aliases (kommagetrennt)</label>
                        <InputText @bind-Value="aliasesInput" class="form-control" placeholder="mistral, large, mistral-large" />
                    </div>
                    
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> Hinzufügen
                    </button>
                </EditForm>
            </div>
        </div>
    </div>

    <!-- Model List -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Gespeicherte Modelle (@models.Count)</h5>
            </div>
            <div class="card-body">
                @if (!models.Any())
                {
                    <p class="text-muted">Noch keine Modelle gespeichert.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var model in models)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">@model.Name</h6>
                                        <code class="small">@model.InternalName</code>
                                        @if (!string.IsNullOrEmpty(model.Description))
                                        {
                                            <p class="mb-1 small text-muted">@model.Description</p>
                                        }
                                        @if (model.Aliases.Any())
                                        {
                                            <small class="text-muted">
                                                Aliases: @string.Join(", ", model.Aliases)
                                            </small>
                                        }
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteModel(model)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<ModelFavorite> models = [];
    private ModelFavorite newModel = new() { Name = "", InternalName = "" };
    private string aliasesInput = "";
    private List<string> providers = [];
    private List<string> allProviderModels = [];
    private List<string> filteredModels = [];
    private string selectedProvider = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadModels();
        await LoadProviders();
    }

    private async Task LoadModels()
    {
        models = await Db.ModelFavorites.OrderBy(m => m.Name).ToListAsync();
    }

    private async Task LoadProviders()
    {
        providers = ProviderManager.GetProviders().ToList();
    }

    private async Task LoadProviderModels()
    {
        allProviderModels.Clear();
        filteredModels.Clear();
        if (string.IsNullOrEmpty(selectedProvider)) return;

        await foreach (var model in ProviderManager.GetModelsAsync(selectedProvider))
        {
            allProviderModels.Add($"{selectedProvider}/{model}");
        }
    }

    private void OnModelInput(ChangeEventArgs e)
    {
        var search = e.Value?.ToString()?.ToLower() ?? "";
        if (string.IsNullOrEmpty(search))
        {
            filteredModels = [];
        }
        else
        {
            filteredModels = allProviderModels
                .Where(m => m.ToLower().Contains(search))
                .Take(10)
                .ToList();
        }
    }

    private void SelectModel(string model)
    {
        newModel.InternalName = model;
        filteredModels = [];
    }

    private async Task AddModel()
    {
        // Parse aliases
        if (!string.IsNullOrWhiteSpace(aliasesInput))
        {
            newModel.Aliases = aliasesInput
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
        }

        Db.ModelFavorites.Add(newModel);
        await Db.SaveChangesAsync();

        newModel = new ModelFavorite { Name = "", InternalName = "" };
        aliasesInput = "";
        selectedProvider = "";
        allProviderModels = [];
        filteredModels = [];
        await LoadModels();
    }

    private async Task DeleteModel(ModelFavorite model)
    {
        Db.ModelFavorites.Remove(model);
        await Db.SaveChangesAsync();
        await LoadModels();
    }
}