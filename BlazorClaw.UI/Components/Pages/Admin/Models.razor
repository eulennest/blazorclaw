@page "/admin/models"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Models
@using BlazorClaw.Core.Providers
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IProviderManager ProviderManager

<PageTitle>Modelle - BlazorClaw</PageTitle>

<h2>Model-Favoriten</h2>
<p class="text-muted">Verwalte deine Lieblingsmodelle für den Chat.</p>

<div class="row mt-4">
    <!-- Add New Model -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">@(editingModel == null ? "Neues Modell hinzufügen" : "Modell bearbeiten")</h5>
            </div>
            <div class="card-body">
                <EditForm Model="formModel" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText @bind-Value="formModel.Name" class="form-control" placeholder="z.B. Mistral Large" />
                        <ValidationMessage For="() => formModel.Name" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Beschreibung</label>
                        <InputTextArea @bind-Value="formModel.Description" class="form-control" placeholder="Kurze Beschreibung..." rows="2" />
                    </div>
                    
                    @if (editingModel == null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Provider wählen</label>
                            <select class="form-select" @bind="selectedProvider" @bind:after="LoadProviderModels">
                                <option value="">-- Provider auswählen --</option>
                                @foreach (var provider in providers)
                                {
                                    <option value="@provider">@provider</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Interner Name</label>
                            <InputText @bind-Value="formModel.InternalName" 
                                @oninput="OnModelInput"
                                class="form-control" 
                                placeholder="Tippe um zu suchen..." />
                            <ValidationMessage For="() => formModel.InternalName" />
                            @if (filteredModels.Any())
                            {
                                <ul class="list-group mt-1" style="max-height: 150px; overflow-y: auto; position: absolute; z-index: 1000; width: calc(100% - 3rem);">
                                    @foreach (var model in filteredModels)
                                    {
                                        <li class="list-group-item list-group-item-action" 
                                            style="cursor: pointer;" 
                                            @onclick="() => SelectModel(model)">
                                            @model
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Interner Name</label>
                            <InputText @bind-Value="formModel.InternalName" class="form-control" />
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label class="form-label">Aliases (kommagetrennt)</label>
                        <InputText @bind-Value="aliasesInput" class="form-control" placeholder="mistral, large, mistral-large" />
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> @(editingModel == null ? "Hinzufügen" : "Speichern")
                        </button>
                        @if (editingModel != null)
                        {
                            <button type="button" class="btn btn-secondary" @onclick="CancelEdit">
                                Abbrechen
                            </button>
                        }
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <!-- Model List -->
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Gespeicherte Modelle (@models.Count)</h5>
            </div>
            <div class="card-body">
                @if (!models.Any())
                {
                    <p class="text-muted">Noch keine Modelle gespeichert.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Modell</th>
                                    <th>Aliases</th>
                                    <th style="width: 100px;">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var model in models)
                                {
                                    <tr>
                                        <td>
                                            <strong>@model.Name</strong>
                                            @if (!string.IsNullOrEmpty(model.Description))
                                            {
                                                <br><small class="text-muted">@model.Description</small>
                                            }
                                        </td>
                                        <td><code class="small">@model.InternalName</code></td>
                                        <td>
                                            @if (model.Aliases.Any())
                                            {
                                                <small class="text-muted">@string.Join(", ", model.Aliases)</small>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditModel(model)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteModel(model)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<ModelFavorite> models = [];
    private ModelFavorite formModel = new() { Name = "", InternalName = "" };
    private ModelFavorite? editingModel;
    private string aliasesInput = "";
    private List<string> providers = [];
    private List<string> allProviderModels = [];
    private List<string> filteredModels = [];
    private string selectedProvider = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadModels();
        await LoadProviders();
    }

    private async Task LoadModels()
    {
        models = await Db.ModelFavorites.OrderBy(m => m.Name).ToListAsync();
    }

    private async Task LoadProviders()
    {
        providers = ProviderManager.GetProviders().ToList();
    }

    private async Task LoadProviderModels()
    {
        allProviderModels.Clear();
        filteredModels.Clear();
        if (string.IsNullOrEmpty(selectedProvider)) return;

        await foreach (var model in ProviderManager.GetModelsAsync(selectedProvider))
        {
            allProviderModels.Add($"{selectedProvider}/{model}");
        }
    }

    private void OnModelInput(ChangeEventArgs e)
    {
        var search = e.Value?.ToString()?.ToLower() ?? "";
        if (string.IsNullOrEmpty(search))
        {
            filteredModels = [];
        }
        else
        {
            filteredModels = allProviderModels
                .Where(m => m.ToLower().Contains(search))
                .Take(10)
                .ToList();
        }
    }

    private void SelectModel(string model)
    {
        formModel.InternalName = model;
        filteredModels = [];
    }

    private async Task HandleSubmit()
    {
        if (editingModel == null)
            await AddModel();
        else
            await SaveEdit();
    }

    private void EditModel(ModelFavorite model)
    {
        editingModel = model;
        formModel = new ModelFavorite
        {
            Id = model.Id,
            Name = model.Name,
            InternalName = model.InternalName,
            Description = model.Description,
            Aliases = model.Aliases.ToList()
        };
        aliasesInput = string.Join(", ", model.Aliases);
    }

    private void CancelEdit()
    {
        editingModel = null;
        formModel = new ModelFavorite { Name = "", InternalName = "" };
        aliasesInput = "";
    }

    private async Task SaveEdit()
    {
        if (editingModel == null) return;

        // Parse aliases
        if (!string.IsNullOrWhiteSpace(aliasesInput))
        {
            formModel.Aliases = aliasesInput
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
        }

        // Update existing model
        var existing = await Db.ModelFavorites.FindAsync(editingModel.Id);
        if (existing != null)
        {
            existing.Name = formModel.Name;
            existing.InternalName = formModel.InternalName;
            existing.Description = formModel.Description;
            existing.Aliases = formModel.Aliases;
            await Db.SaveChangesAsync();
        }

        CancelEdit();
        await LoadModels();
    }

    private async Task AddModel()
    {
        // Parse aliases
        if (!string.IsNullOrWhiteSpace(aliasesInput))
        {
            formModel.Aliases = aliasesInput
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
        }

        Db.ModelFavorites.Add(formModel);
        await Db.SaveChangesAsync();

        formModel = new ModelFavorite { Name = "", InternalName = "" };
        aliasesInput = "";
        selectedProvider = "";
        allProviderModels = [];
        filteredModels = [];
        await LoadModels();
    }

    private async Task DeleteModel(ModelFavorite model)
    {
        Db.ModelFavorites.Remove(model);
        await Db.SaveChangesAsync();
        await LoadModels();
    }
}