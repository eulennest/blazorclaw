@page "/admin/channels/telegram"
@using BlazorClaw.Channels.Services
@using BlazorClaw.UI.Utils
@using Microsoft.Extensions.Options
@inject NavigationManager Navigation
@inject IOptionsMonitor<BotConfigs<TelegramBotEntry>> config
@inject IConfiguration Configuration

<PageTitle>Admin - Telegram</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Telegram Kanal-Verwaltung</h2>
        <p class="text-muted">Verwaltung von Telegram-Bot-Accounts.</p>
    </div>
    <button class="btn btn-secondary" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Zurück</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-telegram"></i> Telegram Bots</h5>
        <button class="btn btn-sm btn-success" @onclick="() => LoadEditModal()">
            <i class="bi bi-plus-circle"></i> Neuer Account
        </button>
    </div>
    <div class="card-body">
        @if (config.CurrentValue.Count == 0)
        {
            <div class="alert alert-info">Keine Bots konfiguriert.</div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Identifier</th>
                        <th>Status</th>
                        <th>User ID</th>
                        <th>Token</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in config.CurrentValue)
                    {
                        <tr>
                            <td><code>@entry.Key</code></td>
                            <td>
                                @if (!entry.Value.Enabled)
                                {
                                    <span class="badge bg-secondary">Deaktiviert</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Aktiv</span>
                                }
                            </td>
                            <td><code>@ExtractUserId(entry.Value.Token)</code></td>
                            <td><code>@MaskToken(entry.Value.Token)</code></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => LoadEditModal(entry.Key)">
                                    <i class="bi bi-pencil"></i> Bearbeiten
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(entry.Key)">
                                    <i class="bi bi-trash"></i> Löschen
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (editModel != null && (formMode == CRUDMode.Create || formMode == CRUDMode.Edit))
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(formMode == CRUDMode.Edit ? "Account bearbeiten" : "Neuer Account")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Identifier</label>
                        <input type="text" class="form-control" @bind="editModelKey" disabled="@(formMode == CRUDMode.Edit)" placeholder="Bot ID (z.B. default)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bot Token</label>
                        <input type="text" class="form-control" @bind="editModel.Token" placeholder="Bot Token" />
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="enabledSwitch" @bind="editModel.Enabled" />
                        <label class="form-check-label" for="enabledSwitch">Enabled</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Abbrechen</button>
                    <button class="btn btn-success" @onclick="SaveAccount">Speichern</button>
                </div>
            </div>
        </div>
    </div>
}

@if (formMode == CRUDMode.Delete)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Löschen bestätigen</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <p>Möchten Sie den Bot <strong>"@editModelKey"</strong> wirklich löschen?</p>
                    <p class="text-muted">Diese Aktion kann nicht rückgängig gemacht werden.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Abbrechen</button>
                    <button class="btn btn-danger" @onclick="DeleteAccount">Löschen</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private TelegramBotEntry? editModel;
    private string? editModelKey;
    private CRUDMode formMode;
    private string? errorMessage, successMessage;

    protected override void OnInitialized()
    {
        config.OnChange(_ => RefreshData());
    }

    private void LoadData() { }

    private void RefreshData() { LoadData(); StateHasChanged(); }

    private string MaskToken(string token) => token.Length > 8 ? token[..4] + "..." + token[^4..] : "****";

    private string ExtractUserId(string token)
    {
        var parts = token.Split(':');
        return parts.Length > 0 ? parts[0] : "Ungültig";
    }

    private void LoadEditModal(string? id = null)
    {
        editModelKey = id;
        editModel = string.IsNullOrWhiteSpace(id) ? new() { Enabled = true, Token = "" }
            : config.CurrentValue.FirstOrDefault(c => c.Key == id).Value?.Clone() as TelegramBotEntry;
        if (editModel == null) return;

        formMode = string.IsNullOrWhiteSpace(id) ? CRUDMode.Create : CRUDMode.Edit;
    }

    private void SaveAccount()
    {
        if (editModel == null || string.IsNullOrWhiteSpace(editModelKey)) return;
        config.CurrentValue.Save(Configuration, editModelKey, editModel);
        successMessage = $"Account '{editModelKey}' erfolgreich {((formMode == CRUDMode.Edit) ? "aktualisiert" : "hinzugefügt")}!";
        CloseModal();
        RefreshData();
    }

    private void ConfirmDelete(string id)
    {
        formMode = CRUDMode.Delete;
        editModelKey = id;
    }

    private void DeleteAccount()
    {
        if (formMode != CRUDMode.Delete || string.IsNullOrEmpty(editModelKey)) return;
        config.CurrentValue.Delete(Configuration, editModelKey);
        successMessage = "Account gelöscht.";
        editModelKey = null;
        CloseModal();
        RefreshData();
    }

    private void CloseModal() { formMode = CRUDMode.None; editModelKey = null; }
    private void GoBack() => Navigation.NavigateTo("/admin/channels");
}