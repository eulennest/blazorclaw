@page "/admin/channels/telegram"
@using BlazorClaw.Channels.Services
@using Microsoft.Extensions.Options
@using System.Linq
@inject NavigationManager Navigation
@inject IOptionsMonitor<BotConfigs<TelegramBotEntry>> configs
@inject IConfiguration Configuration

<PageTitle>Admin - Telegram</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Telegram Kanal-Verwaltung</h2>
        <p class="text-muted">Verwaltung von Telegram-Bot-Accounts.</p>
    </div>
    <button class="btn btn-secondary" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Zurück</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage)) { <div class="alert alert-danger">@errorMessage</div> }
@if (!string.IsNullOrEmpty(successMessage)) { <div class="alert alert-success">@successMessage</div> }

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-telegram"></i> Telegram Bots</h5>
        <button class="btn btn-sm btn-success" @onclick="ShowAddModal"><i class="bi bi-plus-circle"></i> Neuer Account</button>
    </div>
    <div class="card-body">
        @if (bots.Count == 0) { <p class="text-muted">Keine Bots konfiguriert.</p> }
        else {
            <table class="table table-hover">
                <thead><tr><th>Identifier</th><th>User ID</th><th>Token</th><th>Aktionen</th></tr></thead>
                <tbody>
                    @foreach (var entry in bots) {
                        <tr>
                            <td><code>@entry.Key</code></td>
                            <td><code>@ExtractUserId(entry.Value.Token)</code></td>
                            <td><code>@MaskToken(entry.Value.Token)</code></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => ConfirmEditModal(entry.Key)">
                                    <i class="bi bi-pencil"></i> Bearbeiten
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBot(entry.Key)">
                                    <i class="bi bi-trash"></i> Löschen
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (showAddModal) {
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5>@(isEditMode ? "Bot bearbeiten" : "Neuer Telegram Bot")</h5></div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Identifier</label>
                        <input class="form-control" @bind="newId" disabled="@isEditMode" placeholder="Bot ID (z.B. default)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bot Token</label>
                        <input class="form-control" @bind="newToken" placeholder="Bot Token" />
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="enabledSwitch" @bind="newEnabled" />
                        <label class="form-check-label" for="enabledSwitch">Enabled</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="()=>showAddModal=false">Abbrechen</button>
                    <button class="btn btn-success" @onclick="SaveBot">Speichern</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Dictionary<string, TelegramBotEntry> bots = new();
    private bool showAddModal, isEditMode;
    private string newId = "", newToken = "";
    private bool newEnabled = true;
    private string? errorMessage, successMessage;

    protected override void OnInitialized() => LoadBots();

    private void LoadBots()
    {
        bots = configs.CurrentValue.ToDictionary(b => b.Key, b => b.Value);
    }

    private string MaskToken(string token) => token.Length > 8 ? token[..4] + "..." + token[^4..] : "****";

    private string ExtractUserId(string token)
    {
        var parts = token.Split(':');
        return parts.Length > 0 ? parts[0] : "Ungültig";
    }

    private void ShowAddModal() => ConfirmAddModal();

    private void ConfirmAddModal()
    {
        newId = string.Empty;
        newToken = string.Empty;
        newEnabled = true;
        isEditMode = false;
        showAddModal = true;
    }

    private void ConfirmEditModal(string id)
    {
        newId = id;
        newToken = bots[id].Token;
        newEnabled = bots[id].Enabled;
        isEditMode = true;
        showAddModal = true;
    }

    private void SaveBot()
    {
        var section = BotConfigs<TelegramBotEntry>.Section;
        Configuration[$"{section}:{newId}:Token"] = newToken;
        Configuration[$"{section}:{newId}:Enabled"] = newEnabled.ToString();
        showAddModal = false;
        LoadBots();
    }

    private void DeleteBot(string id)
    {
        var section = BotConfigs<TelegramBotEntry>.Section;
        Configuration[$"{section}:{id}"] = null;
        LoadBots();
    }

    private void GoBack() => Navigation.NavigateTo("/admin/channels");
}
