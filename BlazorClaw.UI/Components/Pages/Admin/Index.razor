@page "/admin"

<PageTitle>Admin - Übersicht</PageTitle>

<h1>Konfiguration</h1>
<p>Übersicht über alle Konfigurationsoptionen.</p>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-sliders"></i> Allgemein</h5>
                <p class="card-text text-muted">Grundlegende Einstellungen</p>
                <a href="admin/general" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-chat-dots"></i> Kanäle</h5>
                <p class="card-text text-muted">Telegram, Matrix, Web</p>
                <a href="admin/channels" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-plug-fill"></i> Provider</h5>
                <p class="card-text text-muted">LLM-Anbieter</p>
                <a href="admin/providers" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-shield-lock"></i> Sicherheit</h5>
                <p class="card-text text-muted">Policies, Rollen</p>
                <a href="admin/security" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-key-fill"></i> API-Keys</h5>
                <p class="card-text text-muted">Token-Verwaltung</p>
                <a href="admin/apikeys" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-shield-lock"></i> OAuth-Server</h5>
                <p class="card-text text-muted">OIDC / Discovery / Endpoints</p>
                <a href="admin/oauthservers" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-robot"></i> Modelle</h5>
                <p class="card-text text-muted">Favoriten, Aliases</p>
                <a href="admin/models" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-clock-history"></i> Cron-Jobs</h5>
                <p class="card-text text-muted">Automatisierte Aufgaben</p>
                <a href="admin/crontabs" class="btn btn-primary btn-sm">Verwalten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-clipboard-data"></i> Audit Logs</h5>
                <p class="card-text text-muted">Systemaktionen & Events</p>
                <a href="admin/auditlogs" class="btn btn-primary btn-sm">Ansehen</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-folder-open"></i> Memory-Verwaltung</h5>
                <p class="card-text text-muted">User-Memory-Dateien</p>
                <a href="admin/memory" class="btn btn-primary btn-sm">Verwalten</a>
            </div>
        </div>
    </div>
</div>
