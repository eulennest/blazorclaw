@page "/admin"
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject ILogger<Index> Logger

<PageTitle>Admin - Übersicht</PageTitle>

<h1>Konfiguration</h1>
<p>Übersicht über alle Konfigurationsoptionen.</p>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-sliders"></i> Allgemein</h5>
                <p class="card-text text-muted">Grundlegende Einstellungen</p>
                <a href="admin/general" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-chat-dots"></i> Kanäle</h5>
                <p class="card-text text-muted">Telegram, Matrix, Web</p>
                <a href="admin/channels" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-plug-fill"></i> Provider</h5>
                <p class="card-text text-muted">LLM-Anbieter</p>
                <a href="admin/providers" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-shield-lock"></i> Sicherheit</h5>
                <p class="card-text text-muted">Policies, Rollen</p>
                <a href="admin/security" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-key-fill"></i> API-Keys</h5>
                <p class="card-text text-muted">Token-Verwaltung</p>
                <a href="admin/apikeys" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-robot"></i> Modelle</h5>
                <p class="card-text text-muted">Favoriten, Aliases</p>
                <a href="admin/models" class="btn btn-primary btn-sm">Bearbeiten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-clock-history"></i> Cron-Jobs</h5>
                <p class="card-text text-muted">Automatisierte Aufgaben</p>
                <a href="admin/crontabs" class="btn btn-primary btn-sm">Verwalten</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-clipboard-data"></i> Audit Logs</h5>
                <p class="card-text text-muted">Systemaktionen & Events</p>
                <a href="admin/auditlogs" class="btn btn-primary btn-sm">Ansehen</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-folder-open"></i> Memory-Verwaltung</h5>
                <p class="card-text text-muted">User-Memory-Dateien</p>
                <a href="admin/memory" class="btn btn-primary btn-sm">Verwalten</a>
            </div>
        </div>
    </div>
</div>

<!-- Sessions List -->
<div class="row mt-5">
    <div class="col-12">
        <h3><i class="bi bi-chat-left-text"></i> Chat-Sitzungen</h3>
        <p class="text-muted">Aktuelle Sitzungen verwalten</p>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Sitzungen (@totalSessions)</h5>
                <button class="btn btn-sm btn-outline-primary" @onclick="ReloadSessions">
                    <i class="bi bi-arrow-clockwise"></i> Aktualisieren
                </button>
            </div>
            <div class="card-body">
                @if (sessions == null)
                {
                    <div class="spinner-border spinner-border-sm" role="status">
                        <span class="visually-hidden">Laden...</span>
                    </div>
                }
                else if (!sessions.Any())
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> Keine Sitzungen vorhanden.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 30%;">Titel</th>
                                    <th style="width: 20%;">Benutzer</th>
                                    <th style="width: 15%;">Erstellt</th>
                                    <th style="width: 15%;">Zuletzt verwendet</th>
                                    <th style="width: 10%;">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var session in sessions)
                                {
                                    <tr>
                                        <td>
                                            <strong>@(session.Title ?? "Untitled")</strong>
                                            <br/>
                                            <small class="text-muted">@session.Id.ToString().Substring(0, 8)...</small>
                                        </td>
                                        <td>
                                            <code class="small">@session.UserId.Substring(0, Math.Min(8, session.UserId.Length))...</code>
                                        </td>
                                        <td>
                                            <small>@session.CreatedAt.ToString("dd.MM.yy HH:mm")</small>
                                        </td>
                                        <td>
                                            <small>@session.LastUsedAt.ToString("dd.MM.yy HH:mm")</small>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" 
                                                    @onclick="() => ShowDeleteConfirmation(session)" 
                                                    disabled="@isDeleting">
                                                <i class="bi bi-trash"></i> Löschen
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal @(showDeleteModal ? "show d-block" : "")" tabindex="-1" style="@(showDeleteModal ? "display: block; background: rgba(0,0,0,0.5);" : "display: none;")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Sitzung löschen</h5>
                <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
            </div>
            <div class="modal-body">
                @if (sessionToDelete != null)
                {
                    <p>Möchtest du die Sitzung <strong>"@sessionToDelete.Title"</strong> wirklich löschen?</p>
                    <p class="text-warning"><small><i class="bi bi-exclamation-triangle"></i> Diese Aktion kann nicht rückgängig gemacht werden.</small></p>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">Abbrechen</button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Löschen
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ChatSession>? sessions;
    private int totalSessions;
    private bool showDeleteModal = false;
    private ChatSession? sessionToDelete;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        await ReloadSessions();
    }

    private async Task ReloadSessions()
    {
        try
        {
            sessions = await Db.ChatSessions
                .OrderByDescending(s => s.LastUsedAt)
                .ToListAsync();
            totalSessions = sessions.Count;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading sessions");
        }
    }

    private void ShowDeleteConfirmation(ChatSession session)
    {
        sessionToDelete = session;
        showDeleteModal = true;
    }

    private async Task ConfirmDelete()
    {
        if (sessionToDelete == null)
            return;

        isDeleting = true;
        try
        {
            // Delete from database
            Db.ChatSessions.Remove(sessionToDelete);
            await Db.SaveChangesAsync();

            showDeleteModal = false;
            sessionToDelete = null;
            await ReloadSessions();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting session");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
