@page "/admin/channels/matrix"
@using BlazorClaw.Channels.Services
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<PageTitle>Admin - Matrix</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Matrix Kanal-Verwaltung</h2>
    <button class="btn btn-secondary" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Zurück</button>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Matrix Bots</h5>
        <button class="btn btn-sm btn-success" @onclick="ShowAddModal">Bot hinzufügen</button>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead><tr><th>ID</th><th>Homeserver</th><th>User ID</th><th>Enabled</th><th>Aktionen</th></tr></thead>
            <tbody>
                @foreach (var bot in bots) {
                    <tr>
                        <td><code>@bot.Key</code></td>
                        <td>@bot.Value.Homeserver</td>
                        <td>@bot.Value.UserId</td>
                        <td><input type="checkbox" checked="@bot.Value.Enabled" @onchange="(e) => ToggleEnabled(bot.Key, (bool)e.Value!)" /></td>
                        <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBot(bot.Key)">Löschen</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (showAddModal) {
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5>Neuer Matrix Bot</h5></div>
                <div class="modal-body">
                    <input class="form-control mb-2" @bind="newId" placeholder="Bot ID" />
                    <input class="form-control mb-2" @bind="newHomeserver" placeholder="Homeserver URL" />
                    <input class="form-control mb-2" @bind="newUserId" placeholder="User ID" />
                    <input class="form-control mb-2" @bind="newPassword" type="password" placeholder="Passwort" />
                    <label><input type="checkbox" @bind="newEnabled" /> Enabled</label>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-success" @onclick="SaveBot">Speichern</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Dictionary<string, MatrixBotEntry> bots = new();
    private bool showAddModal;
    private string newId = "", newHomeserver = "https://matrix.org", newUserId = "", newPassword = "";
    private bool newEnabled = true;

    protected override void OnInitialized() => LoadBots();

    private void LoadBots()
    {
        bots.Clear();
        var section = Configuration.GetSection("Channels:Matrix:Accounts");
        foreach(var item in section.GetChildren()) 
            bots[item.Key] = item.Get<MatrixBotEntry>() ?? new MatrixBotEntry();
    }

    private void ShowAddModal() => showAddModal = true;

    private void ToggleEnabled(string id, bool enabled)
    {
        Configuration[$"Channels:Matrix:Accounts:{id}:Enabled"] = enabled.ToString();
        LoadBots();
    }

    private void SaveBot()
    {
        Configuration[$"Channels:Matrix:Accounts:{newId}:Homeserver"] = newHomeserver;
        Configuration[$"Channels:Matrix:Accounts:{newId}:UserId"] = newUserId;
        Configuration[$"Channels:Matrix:Accounts:{newId}:Password"] = newPassword;
        Configuration[$"Channels:Matrix:Accounts:{newId}:Enabled"] = newEnabled.ToString();
        showAddModal = false;
        LoadBots();
    }

    private void DeleteBot(string id)
    {
        Configuration[$"Channels:Matrix:Accounts:{id}"] = null;
        LoadBots();
    }

    private void GoBack() => Navigation.NavigateTo("/admin/channels");
}
