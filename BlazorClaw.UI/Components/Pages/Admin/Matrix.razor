@page "/admin/channels/matrix"
@using BlazorClaw.Channels.Services
@using Microsoft.Extensions.Options
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IOptionsMonitor<BotConfigs<MatrixBotEntry>> MatrixOptions

<PageTitle>Admin - Matrix</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Matrix Kanal-Verwaltung</h2>
        <p class="text-muted">Verwaltung von Matrix-Bot-Accounts.</p>
    </div>
    <button class="btn btn-secondary" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Zurück</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage)) { <div class="alert alert-danger">@errorMessage</div> }
@if (!string.IsNullOrEmpty(successMessage)) { <div class="alert alert-success">@successMessage</div> }

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-person-workspace"></i> Matrix Bots</h5>
        <button class="btn btn-sm btn-success" @onclick="ShowAddModal"><i class="bi bi-plus-circle"></i> Neuer Account</button>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead><tr><th>Identifier</th><th>Enabled</th><th>Homeserver</th><th>User ID</th><th>Aktionen</th></tr></thead>
            <tbody>
                @foreach (var entry in bots) {
                    <tr>
                        <td><code>@entry.Key</code></td>
                        <td><input type="checkbox" checked="@entry.Value.Enabled" @onchange="(e) => ToggleEnabled(entry.Key, (bool)e.Value!)" /></td>
                        <td>@entry.Value.Homeserver</td>
                        <td>@entry.Value.UserId</td>
                        <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBot(entry.Key)">Löschen</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (showAddModal) {
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5>Neuer Matrix Bot</h5></div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Identifier</label>
                        <input class="form-control" @bind="newId" placeholder="Bot ID" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Homeserver</label>
                        <input class="form-control" @bind="newHomeserver" placeholder="https://matrix.org" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">User ID</label>
                        <input class="form-control" @bind="newUserId" placeholder="@@bot:example.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Passwort</label>
                        <input class="form-control" @bind="newPassword" type="password" />
                    </div>
                    <label><input type="checkbox" @bind="newEnabled" /> Enabled</label>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="()=>showAddModal=false">Abbrechen</button>
                    <button class="btn btn-success" @onclick="SaveBot">Speichern</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Dictionary<string, MatrixBotEntry> bots = new();
    private bool showAddModal;
    private string newId = "", newHomeserver = "https://matrix.org", newUserId = "", newPassword = "";
    private bool newEnabled = true;
    private string? errorMessage, successMessage;

    protected override void OnInitialized() => LoadBots();

    private void LoadBots()
    {
        bots = MatrixOptions.CurrentValue.ToDictionary(x => x.Key, x => x.Value);
    }

    private void ShowAddModal() => showAddModal = true;

    private void ToggleEnabled(string id, bool enabled)
    {
        Configuration[$"{BotConfigs<MatrixBotEntry>.Section}:{id}:Enabled"] = enabled.ToString();
        LoadBots();
    }

    private void SaveBot()
    {
        var section = BotConfigs<MatrixBotEntry>.Section;
        Configuration[$"{section}:{newId}:Homeserver"] = newHomeserver;
        Configuration[$"{section}:{newId}:UserId"] = newUserId;
        Configuration[$"{section}:{newId}:Password"] = newPassword;
        Configuration[$"{section}:{newId}:Enabled"] = newEnabled.ToString();
        showAddModal = false;
        LoadBots();
    }

    private void DeleteBot(string id)
    {
        var section = BotConfigs<MatrixBotEntry>.Section;
        Configuration[$"{section}:{id}"] = null;
        LoadBots();
    }

    private void GoBack() => Navigation.NavigateTo("/admin/channels");
}
