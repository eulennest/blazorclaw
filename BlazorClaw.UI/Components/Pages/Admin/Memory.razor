@page "/admin/memory"
@using BlazorClaw.Core.Data
@using BlazorClaw.Core.Services
@using BlazorClaw.Core.Utils
@using Microsoft.EntityFrameworkCore
@inject ILogger<Memory> Logger
@inject ApplicationDbContext db
@inject IServiceProvider provider


<PageTitle>Admin - Memory Verwaltung</PageTitle>

<h2>Memory Verwaltung</h2>
<p class="text-muted">Verwalte Memory-Dateien für alle Benutzer.</p>

<div class="row mt-4">
    <!-- User List -->
    <div class="col-md-3">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Benutzer</h5>
            </div>
            <div class="card-body" style="max-height: 600px; overflow-y: auto;">
                @if (users == null)
                {
                    <div class="spinner-border spinner-border-sm" role="status">
                        <span class="visually-hidden">Laden...</span>
                    </div>
                }
                else if (!users.Any())
                {
                    <div class="alert alert-info mb-0">Keine Benutzer gefunden.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var user in users)
                        {
                            <button class="list-group-item list-group-item-action @(selectedUserId == user.Key ? "active" : "")"
                                    @onclick="() => SelectUser(user.Key)">
                                <div class="fw-bold">@user.Value</div>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Files & Editor -->
    <div class="col-md-9">
        @if (selectedUserId == null)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Wähle einen Benutzer, um seine Memory-Dateien anzuschauen.
            </div>
        }
        else
        {
            <div class="row">
                <!-- File List -->
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Dateien</h5>
                            <button class="btn btn-sm btn-primary" @onclick="() => ShowNewFileModal()">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                        <div class="card-body" style="max-height: 600px; overflow-y: auto;">
                            @if (memoryFiles == null)
                            {
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Laden...</span>
                                </div>
                            }
                            else if (!memoryFiles.Any())
                            {
                                <div class="alert alert-info mb-0">Keine Dateien vorhanden.</div>
                            }
                            else
                            {
                                <div class="list-group list-group-flush">
                                    @foreach (var file in memoryFiles)
                                    {
                                        <button class="list-group-item list-group-item-action @(selectedFile == file ? "active" : "")"
                                                @onclick="() => SelectFile(file)">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <div class="fw-bold small">@file.Name</div>
                                                    <small class="text-muted">@(file.Length) bytes</small>
                                                </div>
                                            </div>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Editor -->
                <div class="col-md-8">
                    @if (selectedFile == null)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Wähle eine Datei zum Editieren.
                        </div>
                    }
                    else
                    {
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">@selectedFile.Name</h5>
                                <div>
                                    <button class="btn btn-sm btn-success me-2" @onclick="SaveFile" disabled="@isSaving">
                                        <i class="bi bi-check2"></i> Speichern
                                    </button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmation(selectedFile.FullName)" disabled="@isSaving">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                @if (fileContent == null)
                                {
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Laden...</span>
                                    </div>
                                }
                                else
                                {
                                    <textarea @bind="fileContent" class="form-control form-control-sm" style="font-family: monospace; height: 500px; resize: vertical;"></textarea>
                                    @if (!string.IsNullOrEmpty(lastSaveMessage))
                                    {
                                        <div class="alert alert-success mt-2 mb-0">@lastSaveMessage</div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- New File Modal -->
<div class="modal @(showNewFileModal ? "show d-block" : "")" tabindex="-1" style="@(showNewFileModal ? "display: block; background: rgba(0,0,0,0.5);" : "display: none;")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Neue Datei erstellen</h5>
                <button type="button" class="btn-close" @onclick="() => showNewFileModal = false"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Dateiname</label>
                    <input @bind="newFileName" type="text" class="form-control" placeholder="z.B. notes.md oder folder/notes.md" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="() => showNewFileModal = false">Abbrechen</button>
                <button type="button" class="btn btn-primary" @onclick="CreateNewFile">Erstellen</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal @(showDeleteConfirmation ? "show d-block" : "")" tabindex="-1" style="@(showDeleteConfirmation ? "display: block; background: rgba(0,0,0,0.5);" : "display: none;")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Datei löschen</h5>
                <button type="button" class="btn-close" @onclick="() => showDeleteConfirmation = false"></button>
            </div>
            <div class="modal-body">
                <p>Möchtest du die Datei <strong>@fileToDelete</strong> wirklich löschen?</p>
                <p class="text-warning"><small><i class="bi bi-exclamation-triangle"></i> Diese Aktion kann nicht rückgängig gemacht werden.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="() => showDeleteConfirmation = false">Abbrechen</button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Löschen</button>
            </div>
        </div>
    </div>
</div>

@code {
    private Dictionary<Guid, string>? users;
    private Guid? selectedUserId;
    private List<FileInfo>? memoryFiles;
    private FileInfo? selectedFile;

    private string? fileContent;
    private string? lastSaveMessage;
    private bool isSaving = false;
    private bool showNewFileModal = false;
    private string? newFileName;
    private bool showDeleteConfirmation = false;
    private FileInfo? fileToDelete;

    protected override async Task OnInitializedAsync()
    {
        users ??= await LoadUsers();
    }

    private async Task<Dictionary<Guid, string>> LoadUsers()
    {
        var ret = new Dictionary<Guid, string>();
        try
        {
            var basePath = PathUtils.GetAllBasePath(provider);
            var di = new DirectoryInfo(basePath);
            var uList = await db.Users.ToListAsync();

            foreach (var item in di.EnumerateDirectories())
            {
                if (!Guid.TryParse(item.Name, out var uid)) continue;
                var name = uList.FirstOrDefault(u => u.Id.Equals(uid.ToString()))?.UserName ?? item.Name;
                ret.Add(uid, name);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading users");
        }
        return ret;
    }

    private async Task SelectUser(Guid userId)
    {
        selectedUserId = userId;
        selectedFile = null;
        fileToDelete = null;
        fileContent = null;
        lastSaveMessage = null;
        await LoadMemoryFiles();
    }

    private async Task LoadMemoryFiles()
    {
        if (selectedUserId == null) return;
        var memoryBase = Path.Combine(PathUtils.GetUserBasePath(provider, selectedUserId.Value), "memory");
        try
        {
            var di = new DirectoryInfo(memoryBase);
            memoryFiles = di.EnumerateFiles("*.md", SearchOption.AllDirectories).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading memory files");
        }
    }

    private async Task SelectFile(FileInfo file)
    {
        selectedFile = file;
        fileContent = null;
        lastSaveMessage = null;
        await LoadFileContent();
    }

    private async Task LoadFileContent()
    {
        if (selectedUserId == null || selectedFile == null) return;

        try
        {
            fileContent = await File.ReadAllTextAsync(selectedFile.FullName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading file content");
        }
    }

    private async Task SaveFile()
    {
        if (selectedUserId == null || fileContent == null || selectedFile == null) return;

        isSaving = true;
        try
        {
            await File.WriteAllTextAsync(selectedFile.FullName, fileContent);
            lastSaveMessage = "Datei gespeichert ✓";
            await Task.Delay(3000);
            lastSaveMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving file");
            lastSaveMessage = "Fehler beim Speichern!";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowDeleteConfirmation(string? path)
    {
        fileToDelete = memoryFiles?.FirstOrDefault(o => o.FullName == path);
        showDeleteConfirmation = fileToDelete != null;
    }

    private async Task ConfirmDelete()
    {
        if (fileToDelete == null || selectedUserId == null)
            return;

        showDeleteConfirmation = false;

        try
        {
            fileToDelete.Delete();
            selectedFile = null;
            fileToDelete = null;
            fileContent = null;
            await LoadMemoryFiles();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting file");
        }
    }

    private void ShowNewFileModal()
    {
        newFileName = string.Empty;
        showNewFileModal = true;
    }

    private async Task CreateNewFile()
    {
        if (string.IsNullOrWhiteSpace(newFileName) || selectedUserId == null)
            return;

        try
        {
            // await MemoryService.SaveUserMemoryFileAsync(selectedUserId, newFileName, string.Empty);
            showNewFileModal = false;
            newFileName = null;
            await LoadMemoryFiles();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating file");
        }
    }

}
