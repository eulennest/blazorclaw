@page "/admin/channels/whatsapp"
@using BlazorClaw.Channels.Services
@using Microsoft.Extensions.Options
@inject WhatsAppBotHostedService WhatsAppService
@inject NavigationManager Navigation
@inject IConfigurationRoot Configuration
@inject IOptionsMonitor<BotConfigs<WhatsAppBotEntry>> config

<PageTitle>Admin - WhatsApp</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>WhatsApp Kanal-Verwaltung</h2>
        <p class="text-muted">Verwaltung von WhatsApp-Accounts.</p>
    </div>
    <button class="btn btn-secondary" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Zurück</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-whatsapp"></i> WhatsApp Accounts</h5>
        <button class="btn btn-sm btn-success" @onclick="() => LoadEditModal()">
            <i class="bi bi-plus-circle"></i> Neuer Account
        </button>
    </div>
    <div class="card-body">
        @if (config.CurrentValue.Count == 0)
        {
            <div class="alert alert-info">Keine Accounts konfiguriert.</div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Identifier</th>
                        <th>Status</th>
                        <th>Push Name</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in config.CurrentValue)
                    {
                        var hasQR = qrCodes.Any(q => q.AccountId == account.Key);
                        <tr>
                            <td><code>@account.Key</code></td>
                            <td>
                                @if (!account.Value.Enabled)
                                {
                                    <span class="badge bg-secondary">Deaktiviert</span>
                                }
                                else if (hasQR)
                                {
                                    <span class="badge bg-warning">Wartet auf Pairing</span>
                                }
                                else
                                {

                                    <span class="badge bg-success">Aktiv</span>
                                }
                            </td>
                            <td>@account.Value.PushName</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => LoadEditModal(account.Key)">
                                    <i class="bi bi-pencil"></i> Bearbeiten
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(account.Key)">
                                    <i class="bi bi-trash"></i> Löschen
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (editModel != null && (formMode == CRUDMode.Create || formMode == CRUDMode.Edit))
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@( formMode == CRUDMode.Edit ? "Account bearbeiten" : "Neuer Account")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Identifier</label>
                        <input type="text" class="form-control" @bind="editModelKey" disabled="@(formMode == CRUDMode.Edit)" placeholder="z.B. default" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Push Name</label>
                        <input type="text" class="form-control" @bind="editModel.PushName" placeholder="z.B. BlazorClaw Bot" />
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="enabledSwitch" @bind="editModel.Enabled" />
                        <label class="form-check-label" for="enabledSwitch">Enabled</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Abbrechen</button>
                    <button class="btn btn-success" @onclick="SaveAccount">Speichern</button>
                </div>
            </div>
        </div>
    </div>
}

@if (formMode == CRUDMode.Delete)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Löschen bestätigen</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <p>Möchten Sie den Account <strong>"@editModelKey"</strong> wirklich löschen?</p>
                    <p class="text-muted">Diese Aktion kann nicht rückgängig gemacht werden.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Abbrechen</button>
                    <button class="btn btn-danger" @onclick="DeleteAccount">Löschen</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<WhatsAppQRCodeData> qrCodes = new();
    private string SectionName => BotConfigs<WhatsAppBotEntry>.Section;
    private WhatsAppBotEntry? editModel;
    private string? editModelKey;
    private CRUDMode formMode;
    private string? errorMessage, successMessage;

    protected override void OnInitialized()
    {
        LoadData();
        config.OnChange(_ => RefreshData());
    }

    private void LoadData()
    {
        qrCodes = WhatsAppService.GetCurrentQRCodes();
    }

    private void RefreshData() { LoadData(); try { StateHasChanged(); } catch { } }


    private void LoadEditModal(string? id = null)
    {
        editModelKey = id;
        editModel = string.IsNullOrWhiteSpace(id) ? new() { Enabled = true }
        : config.CurrentValue.FirstOrDefault(c => c.Key == id).Value?.Clone() as WhatsAppBotEntry;
        if (editModel == null) return;

        formMode = string.IsNullOrWhiteSpace(id) ? CRUDMode.Create : CRUDMode.Edit;
    }


    private void SaveAccount()
    {
        if (editModel == null || string.IsNullOrWhiteSpace(editModelKey)) return;
        config.CurrentValue.SaveAsync(Configuration, editModelKey, editModel).GetAwaiter().GetResult();
        successMessage = $"Account '{editModelKey}' erfolgreich {((formMode == CRUDMode.Edit) ? "aktualisiert" : "hinzugefügt")}!";
        CloseModal();
        RefreshData();
    }

    private void ConfirmDelete(string id)
    {
        formMode = CRUDMode.Delete;
        editModelKey = id;
    }

    private void DeleteAccount()
    {
        Task.Delay(5).GetAwaiter().GetResult();
        if (formMode != CRUDMode.Delete || string.IsNullOrEmpty(editModelKey)) return;
        config.CurrentValue.DeleteAsync(Configuration, editModelKey).GetAwaiter().GetResult();
        successMessage = "Account gelöscht.";
        editModelKey = null;
        CloseModal();
        RefreshData();
    }

    private void CloseModal() { formMode = CRUDMode.None; editModelKey = null; }
    private void GoBack() => Navigation.NavigateTo("/admin/channels");
}
