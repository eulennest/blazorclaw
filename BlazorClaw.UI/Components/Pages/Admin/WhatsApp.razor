@page "/admin/channels/whatsapp"
@using BlazorClaw.Channels.Services
@using Microsoft.Extensions.Options
@inject WhatsAppBotHostedService WhatsAppService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IOptionsMonitor<BotConfigs<WhatsAppBotEntry>> WhatsAppOptions

<PageTitle>Admin - WhatsApp</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>WhatsApp Kanal-Verwaltung</h2>
        <p class="text-muted">Verwaltung von WhatsApp-Accounts.</p>
    </div>
    <button class="btn btn-secondary" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Zurück</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-whatsapp"></i> WhatsApp Accounts</h5>
        <button class="btn btn-sm btn-success" @onclick="ConfirmAddAccountModal">
            <i class="bi bi-plus-circle"></i> Neuer Account
        </button>
    </div>
    <div class="card-body">
        @if (accounts.Count == 0)
        {
            <div class="alert alert-info">Keine WhatsApp-Accounts konfiguriert.</div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Identifier</th>
                        <th>Enabled</th>
                        <th>Status</th>
                        <th>Push Name</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in accounts)
                    {
                        var hasQR = qrCodes.Any(q => q.AccountId == account.Key);
                        <tr>
                            <td><code>@account.Key</code></td>
                            <td><input type="checkbox" checked="@account.Value.Enabled" @onchange="(e) => ToggleEnabled(account.Key, (bool)e.Value!)" /></td>
                            <td>
                                @if (hasQR) { <span class="badge bg-warning">Wartet auf Pairing</span> }
                                else { <span class="badge bg-success">Verbunden</span> }
                            </td>
                            <td>@account.Value.PushName</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => ConfirmEditAccountModal(account.Key)">
                                    <i class="bi bi-pencil"></i> Bearbeiten
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(account.Key)">
                                    <i class="bi bi-trash"></i> Löschen
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (showAddModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEditMode ? "Account bearbeiten" : "Neuer Account")</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Identifier</label>
                        <input type="text" class="form-control" @bind="newAccountId" disabled="@isEditMode" placeholder="z.B. default" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Push Name</label>
                        <input type="text" class="form-control" @bind="newPushName" placeholder="z.B. BlazorClaw Bot" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseAddModal">Abbrechen</button>
                    <button class="btn btn-success" @onclick="SaveNewAccount">Speichern</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<WhatsAppQRCodeData> qrCodes = new();
    private Dictionary<string, WhatsAppBotEntry> accounts = new();
    private bool showAddModal = false;
    private bool showDeleteModal = false;
    private bool isEditMode = false;
    private string newAccountId = string.Empty;
    private string newPushName = string.Empty;
    private string? accountToDelete = null;
    private string? errorMessage, successMessage;

    protected override void OnInitialized() => LoadData();

    private void LoadData()
    {
        qrCodes = WhatsAppService.GetCurrentQRCodes();
        accounts = WhatsAppOptions.CurrentValue.ToDictionary(x => x.Key, x => x.Value);
    }

    private void RefreshData() { LoadData(); StateHasChanged(); }

    private void ToggleEnabled(string id, bool enabled)
    {
        Configuration[$"{BotConfigs<WhatsAppBotEntry>.Section}:{id}:Enabled"] = enabled.ToString();
        RefreshData();
    }

    private void ConfirmAddAccountModal()
    {
        newAccountId = string.Empty;
        newPushName = string.Empty;
        isEditMode = false;
        showAddModal = true;
    }

    private void ConfirmEditAccountModal(string id)
    {
        newAccountId = id;
        newPushName = accounts[id].PushName ?? string.Empty;
        isEditMode = true;
        showAddModal = true;
    }

    private void CloseAddModal() => showAddModal = false;

    private void SaveNewAccount()
    {
        var section = BotConfigs<WhatsAppBotEntry>.Section;
        Configuration[$"{section}:{newAccountId}:Enabled"] = "true";
        Configuration[$"{section}:{newAccountId}:PushName"] = newPushName;
        successMessage = "Account gespeichert.";
        CloseAddModal();
        RefreshData();
    }

    private void ConfirmDelete(string id) { accountToDelete = id; showDeleteModal = true; }
    private void CloseDeleteModal() { showDeleteModal = false; accountToDelete = null; }
    private void DeleteAccount()
    {
        Configuration[$"{BotConfigs<WhatsAppBotEntry>.Section}:{accountToDelete}"] = null;
        successMessage = "Account gelöscht.";
        CloseDeleteModal();
        RefreshData();
    }
    private void GoBack() => Navigation.NavigateTo("/admin/channels");
    private string GenerateQRCodeB64(string data)
    {
        using var qrGenerator = new QRCoder.QRCodeGenerator();
        using var qrCodeData = qrGenerator.CreateQrCode(data, QRCoder.QRCodeGenerator.ECCLevel.Q);
        using var qrCode = new QRCoder.Base64QRCode(qrCodeData);
        return "data:image/png;base64," + qrCode.GetGraphic(10);
    }
}
