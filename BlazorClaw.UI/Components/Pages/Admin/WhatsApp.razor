@page "/admin/channels/whatsapp"
@using BlazorClaw.Channels.Services
@inject WhatsAppBotHostedService WhatsAppService

<PageTitle>Admin - WhatsApp</PageTitle>

<h2>WhatsApp Kanal-Verwaltung</h2>
<p class="text-muted">Verwaltung von WhatsApp-Accounts und QR-Code-Pairing.</p>

<div class="mt-4">
    @if (qrCodes == null || qrCodes.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Keine QR-Codes vorhanden. Alle WhatsApp-Accounts sind verbunden oder es sind keine Accounts konfiguriert.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var qr in qrCodes)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-whatsapp"></i> @qr.AccountId
                            </h5>
                        </div>
                        <div class="card-body text-center">
                            @* QR-Code als Base64 SVG *@
                            <div class="mb-3">
                                @((MarkupString)GenerateQRCodeSvg(qr.QRCode))
                            </div>
                            
                            <p class="text-muted small">
                                <i class="bi bi-clock"></i> Generiert: @qr.GeneratedAt.ToString("HH:mm:ss")
                            </p>
                            
                            <div class="alert alert-info small">
                                <i class="bi bi-phone"></i> Scanne diesen QR-Code mit WhatsApp auf deinem Handy:
                                <br/>
                                <strong>WhatsApp → Verknüpfte Geräte → Gerät verknüpfen</strong>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="mt-4">
    <button class="btn btn-primary" @onclick="RefreshQRCodes">
        <i class="bi bi-arrow-clockwise"></i> Aktualisieren
    </button>
</div>

@code {
    private List<WhatsAppQRCodeData>? qrCodes;

    protected override void OnInitialized()
    {
        LoadQRCodes();
    }

    private void LoadQRCodes()
    {
        qrCodes = WhatsAppService.GetCurrentQRCodes();
    }

    private void RefreshQRCodes()
    {
        LoadQRCodes();
        StateHasChanged();
    }

    private string GenerateQRCodeSvg(string data)
    {
        using var qrGenerator = new QRCoder.QRCodeGenerator();
        using var qrCodeData = qrGenerator.CreateQrCode(data, QRCoder.QRCodeGenerator.ECCLevel.Q);
        using var qrCode = new QRCoder.SvgQRCode(qrCodeData);
        return qrCode.GetGraphic(20);
    }
}
