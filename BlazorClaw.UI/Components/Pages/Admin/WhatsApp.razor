@page "/admin/channels/whatsapp"
@using BlazorClaw.Channels.Services
@using Microsoft.Extensions.Options
@inject WhatsAppBotHostedService WhatsAppService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IOptionsMonitor<WhatsAppConfigs> WhatsAppOptions

<PageTitle>Admin - WhatsApp</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>WhatsApp Kanal-Verwaltung</h2>
        <p class="text-muted">Verwaltung von WhatsApp-Accounts und QR-Code-Pairing.</p>
    </div>
    <div>
        <button class="btn btn-secondary" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> Zurück
        </button>
    </div>
</div>

<!-- Error/Success Messages -->
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<!-- WhatsApp Accounts Section -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-whatsapp"></i> WhatsApp Accounts</h5>
        <button class="btn btn-sm btn-success" @onclick="ShowAddAccountModal">
            <i class="bi bi-plus-circle"></i> Neuer Account
        </button>
    </div>
    <div class="card-body">
        @if (accounts.Count == 0)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Keine WhatsApp-Accounts konfiguriert.
                <button class="btn btn-link p-0" @onclick="ShowAddAccountModal">Jetzt einen Account hinzufügen</button>
            </div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Account ID</th>
                        <th>Status</th>
                        <th>Push Name</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in accounts)
                    {
                        var hasQR = qrCodes.Any(q => q.AccountId == account.Key);
                        <tr>
                            <td><code>@account.Key</code></td>
                            <td>
                                @if (hasQR)
                                {
                                    <span class="badge bg-warning">Wartet auf Pairing</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Verbunden</span>
                                }
                            </td>
                            <td>@account.Value.PushName</td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(account.Key)">
                                    <i class="bi bi-trash"></i> Löschen
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- QR Codes Section -->
@if (qrCodes.Count > 0)
{
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-qr-code"></i> Offene Pairings</h5>
        </div>
        <div class="card-body">
            <div class="row">
                @foreach (var qr in qrCodes)
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card border-warning">
                            <div class="card-header bg-warning text-dark">
                                <h6 class="mb-0">
                                    <i class="bi bi-whatsapp"></i> @qr.AccountId
                                </h6>
                            </div>
                            <div class="card-body text-center">
                                <img style="max-height:300px" src="@GenerateQRCodeB64(qr.QRCode)"/>
                                <p class="text-muted small mt-3">
                                    <i class="bi bi-clock"></i> Generiert: @qr.GeneratedAt.ToString("HH:mm:ss")
                                </p>
                                
                                <div class="alert alert-info small mb-0">
                                    <i class="bi bi-phone"></i> Scanne diesen QR-Code mit WhatsApp:
                                    <br />
                                    <strong>WhatsApp → Verknüpfte Geräte → Gerät verknüpfen</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            <button class="btn btn-primary" @onclick="RefreshData">
                <i class="bi bi-arrow-clockwise"></i> Aktualisieren
            </button>
        </div>
    </div>
}

<!-- Add Account Modal -->
@if (showAddModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Neuer WhatsApp Account</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Account ID</label>
                        <input type="text" class="form-control" @bind="newAccountId" placeholder="z.B. default, kaspar, daniel" />
                        <small class="form-text text-muted">Eindeutige ID für diesen Account</small>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Push Name</label>
                        <input type="text" class="form-control" @bind="newPushName" placeholder="z.B. BlazorClaw Bot" />
                        <small class="form-text text-muted">Anzeigename für WhatsApp-Nutzer</small>
                    </div>
                    
                    <div class="alert alert-info small">
                        <strong>Auth Directory:</strong> Wird automatisch als <code>./whatsapp_auth/@newAccountId</code> gesetzt.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddModal">Abbrechen</button>
                    <button type="button" class="btn btn-success" @onclick="SaveNewAccount" disabled="@(string.IsNullOrWhiteSpace(newAccountId) || string.IsNullOrWhiteSpace(newPushName))">
                        <i class="bi bi-save"></i> Speichern
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Account löschen</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Möchtest du den WhatsApp-Account <strong>@accountToDelete</strong> wirklich löschen?</p>
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> Diese Aktion kann nicht rückgängig gemacht werden!
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteModal">Abbrechen</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteAccount">
                        <i class="bi bi-trash"></i> Löschen
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<WhatsAppQRCodeData> qrCodes = new();
    private Dictionary<string, WhatsAppConfigEntry> accounts = new();
    private bool showAddModal = false;
    private bool showDeleteModal = false;
    private string newAccountId = string.Empty;
    private string newPushName = string.Empty;
    private string? accountToDelete = null;
    private string? errorMessage = null;
    private string? successMessage = null;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        qrCodes = WhatsAppService.GetCurrentQRCodes();
        accounts = WhatsAppOptions.CurrentValue;
    }

    private void RefreshData()
    {
        LoadData();
        StateHasChanged();
    }

    private void ShowAddAccountModal()
    {
        newAccountId = string.Empty;
        newPushName = string.Empty;
        showAddModal = true;
    }

    private void CloseAddModal()
    {
        showAddModal = false;
    }

    private void SaveNewAccount()
    {
        try
        {
            // Set new account in IConfiguration
            Configuration[$"{WhatsAppConfigs.Section}:{newAccountId}:Enabled"] = "true";
            Configuration[$"{WhatsAppConfigs.Section}:{newAccountId}:PushName"] = newPushName;
            Configuration[$"{WhatsAppConfigs.Section}:{newAccountId}:AuthDir"] = $"./whatsapp_auth/{newAccountId}";

            successMessage = $"Account '{newAccountId}' erfolgreich hinzugefügt! Bitte Server neu starten.";
            CloseAddModal();
            RefreshData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler: {ex.Message}";
        }
    }

    private void ConfirmDelete(string accountId)
    {
        accountToDelete = accountId;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        accountToDelete = null;
    }

    private void DeleteAccount()
    {
        if (accountToDelete == null) return;

        try
        {
            // Remove from IConfiguration (set to null)
            Configuration[$"{WhatsAppConfigs.Section}:{accountToDelete}"] = null;

            successMessage = $"Account '{accountToDelete}' erfolgreich gelöscht! Bitte Server neu starten.";
            CloseDeleteModal();
            RefreshData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler: {ex.Message}";
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/channels");
    }

    private string GenerateQRCodeB64(string data)
    {
        using var qrGenerator = new QRCoder.QRCodeGenerator();
        using var qrCodeData = qrGenerator.CreateQrCode(data, QRCoder.QRCodeGenerator.ECCLevel.Q);
        using var qrCode = new QRCoder.Base64QRCode(qrCodeData);
        return "data:image/png;base64," + qrCode.GetGraphic(10);
    }
}
