@using BlazorClaw.UI.Components.Account.Shared

<Router AppAssembly="typeof(BlazorClaw.UI.Components.Layout.MainLayout).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(BlazorClaw.UI.Components.Layout.MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>